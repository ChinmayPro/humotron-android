<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@color/black">


    <com.facebook.shimmer.ShimmerFrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:shimmer_auto_start="true"
        app:shimmer_base_alpha="0.8"
        app:shimmer_base_color="#ffffff"
        app:shimmer_colored="true"
        app:shimmer_duration="1000"
        app:shimmer_shape="linear">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_15dp"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/_20dp"
                android:layout_marginTop="@dimen/_15dp"
                android:background="@color/white_simmer" />

            <View
                android:layout_width="@dimen/_150dp"
                android:layout_height="@dimen/_20dp"
                android:layout_marginTop="@dimen/_10dp"
                android:background="@color/white_simmer" />

            <View
                android:layout_width="@dimen/_60dp"
                android:layout_height="@dimen/_14dp"
                android:layout_marginTop="@dimen/_30dp"
                android:background="@color/white_simmer" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/_10dp"
                android:layout_marginTop="@dimen/_10dp"
                android:background="@color/white_simmer" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/_10dp"
                android:layout_marginTop="@dimen/_10dp"
                android:background="@color/white_simmer" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/_10dp"
                android:layout_marginTop="@dimen/_10dp"
                android:background="@color/white_simmer" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/_10dp"
                android:layout_marginTop="@dimen/_10dp"
                android:background="@color/white_simmer" />


            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="@dimen/_150dp"
                android:layout_marginTop="@dimen/_15dp"
                android:background="@drawable/bg_btn_round_rect_8"
                android:backgroundTint="@color/white_simmer"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_18dp"
                android:paddingVertical="@dimen/_20dp">


                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_10dp"
                    android:layout_marginTop="@dimen/_10dp"
                    android:background="@color/white_simmer" />

                <View
                    android:layout_width="@dimen/_150dp"
                    android:layout_height="@dimen/_10dp"
                    android:layout_marginTop="@dimen/_10dp"
                    android:background="@color/white_simmer" />


            </androidx.appcompat.widget.LinearLayoutCompat>


        </androidx.appcompat.widget.LinearLayoutCompat>


    </com.facebook.shimmer.ShimmerFrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>