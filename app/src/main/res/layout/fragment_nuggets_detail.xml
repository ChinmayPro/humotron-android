<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@color/black"
    tools:context=".ui.bioHack.NuggetsDetailFragment">


    <include
        android:id="@+id/header"
        layout="@layout/layout_header" />

    <ViewAnimator
        android:id="@+id/viewAnimator"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <include layout="@layout/shimmer_nuggets_detail" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
          >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/scrollRoot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvTitle"
                    style="@style/Text.22x.Manrope.SemiBold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_24dp"
                    android:layout_marginTop="@dimen/_16dp"
                    android:textColor="@color/btn_pink"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Cell Functions - The Lifeline of Your Body" />


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/textview1"
                    style="@style/Text.12x.Manrope.Regular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_24dp"
                    android:layout_marginTop="@dimen/_24dp"
                    android:text="Overview"
                    android:textColor="@color/_97"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvOverview"
                    style="@style/Text.14x.Manrope.Medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_24dp"
                    android:layout_marginTop="@dimen/_8dp"
                    android:text="Discover the essential roles and mechanisms of cellular functions in maintaining overall health and vitality. This detailed guide explores how everyday habits influence cellular processes and offers practical tips to enhance cell function through diet, exercise, and lifestyle adjustments."
                    android:textColor="@color/d70"
                    app:layout_constraintTop_toBottomOf="@id/textview1" />


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDeepDives"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_30dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="true"
                    app:layout_constraintTop_toBottomOf="@id/tvOverview"
                    tools:itemCount="1"
                    tools:listitem="@layout/item_deep_dive" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvRelatedBooks"
                    style="@style/Text.16x.Manrope.Bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_24dp"
                    android:layout_marginTop="@dimen/_8dp"
                    android:text="@string/related_books"
                    android:textColor="@color/textColorWhite"
                    app:layout_constraintTop_toBottomOf="@id/rvDeepDives" />


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBooks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_30dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="true"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/_24dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/tvRelatedBooks"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_biohack_book" />


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/llTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_32dp"
                    android:layout_marginTop="@dimen/_50dp"
                    app:layout_constraintTop_toBottomOf="@id/rvBooks">

                    <TextView
                        android:id="@+id/tvCategory"
                        style="@style/Text.12x.Manrope.Regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rounded_5"
                        android:backgroundTint="@color/black"
                        android:paddingVertical="@dimen/_4dp"
                        android:paddingStart="@dimen/_11dp"
                        android:paddingEnd="@dimen/_24dp"
                        android:text="HEalth &amp; Fitness asfgsd"
                        android:textColor="@color/d600" />

                    <TextView
                        android:id="@+id/tvPrimaryTag"
                        style="@style/Text.12x.Manrope.Regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rounded_5"
                        android:backgroundTint="@color/black"
                        android:paddingVertical="@dimen/_4dp"
                        android:paddingStart="@dimen/_11dp"
                        android:paddingEnd="@dimen/_24dp"
                        android:text="Mental Health "
                        android:textColor="@color/d600" />

                    <TextView
                        android:id="@+id/tvLearning"
                        style="@style/Text.12x.Manrope.Regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rounded_5"
                        android:backgroundTint="@color/black"
                        android:paddingVertical="@dimen/_4dp"
                        android:paddingStart="@dimen/_11dp"
                        android:paddingEnd="@dimen/_24dp"
                        android:text="Sleep Habits as zvf a asv"
                        android:textColor="@color/d600" />

                    <!-- Flow to arrange the TextViews -->
                    <androidx.constraintlayout.helper.widget.Flow
                        android:id="@+id/flow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:constraint_referenced_ids="tvCategory,tvPrimaryTag,tvLearning"
                        app:flow_horizontalAlign="start"
                        app:flow_horizontalGap="@dimen/_8dp"
                        app:flow_verticalGap="@dimen/_17dp"
                        app:flow_wrapMode="aligned"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>


                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivDisLike"
                    android:layout_width="@dimen/_60dp"
                    android:layout_height="@dimen/_60dp"
                    android:layout_marginStart="@dimen/_15dp"
                    android:layout_marginTop="@dimen/_50dp"
                    android:background="@drawable/bg_round_green"
                    android:backgroundTint="@color/_1f"
                    android:padding="@dimen/_18dp"
                    android:src="@drawable/ic_dislike"
                    app:layout_constraintEnd_toStartOf="@id/ivLike"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/llTags" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivLike"
                    android:layout_width="@dimen/_60dp"
                    android:layout_height="@dimen/_60dp"
                    android:background="@drawable/bg_round_green"
                    android:backgroundTint="@color/_1f"
                    android:padding="@dimen/_18dp"
                    android:src="@drawable/ic_like"
                    app:layout_constraintEnd_toStartOf="@id/ivBookMark"
                    app:layout_constraintStart_toEndOf="@id/ivDisLike"
                    app:layout_constraintTop_toTopOf="@id/ivDisLike" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivBookMark"
                    android:layout_width="@dimen/_60dp"
                    android:layout_height="@dimen/_60dp"
                    android:background="@drawable/bg_round_green"
                    android:backgroundTint="@color/_1f"
                    android:padding="@dimen/_18dp"
                    android:src="@drawable/ic_bookmark"
                    app:layout_constraintEnd_toStartOf="@id/ivDetail"
                    app:layout_constraintStart_toEndOf="@id/ivLike"
                    app:layout_constraintTop_toTopOf="@id/ivDisLike" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivDetail"
                    android:layout_width="@dimen/_60dp"
                    android:layout_height="@dimen/_60dp"
                    android:layout_marginEnd="@dimen/_15dp"
                    android:background="@drawable/bg_round_green"
                    android:backgroundTint="@color/_1f"
                    android:padding="@dimen/_18dp"
                    android:src="@drawable/ic_detail_hide"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintStart_toEndOf="@id/ivBookMark"
                    app:layout_constraintTop_toTopOf="@id/ivDisLike" />


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </ViewAnimator>


</androidx.constraintlayout.widget.ConstraintLayout>