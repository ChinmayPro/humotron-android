<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTitle"
            style="@style/Text.24x.Manrope.Bold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/introducing_digital_tools"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:fontFamily="@font/manrope_extra_bold"
            app:fontFamily="@font/manrope_extra_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSubtitle"
            style="@style/Text.14x.Manrope.Medium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/digital_tools_desc"
            android:textColor="@color/white50"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvPlansLabel"
            style="@style/Text.16x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginTop="22dp"
            android:text="Plans"
            android:textColor="#cdd6d5"
            android:fontFamily="@font/manrope_extra_bold"
            app:fontFamily="@font/manrope_extra_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

        <!-- Basic Plan -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardBasicPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="22dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_plan_card"
            android:padding="18dp"
            app:layout_constraintTop_toBottomOf="@id/tvPlansLabel">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvBasicTitle"
                style="@style/Text.20x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Basic"
                android:textColor="@color/white"
                android:fontFamily="@font/manrope_extra_bold"
                app:fontFamily="@font/manrope_extra_bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvBasicDesc"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="@dimen/_200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:lineSpacingExtra="2dp"
                android:text="Your essential dashboard — track sources, read metrics and follow guidance."
                android:textColor="@color/white50"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBasicTitle" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvBasicPrice"
                style="@style/Text.24x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Free"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:fontFamily="@font/manrope_extra_bold"
                app:fontFamily="@font/manrope_extra_bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvBasicDesc" />

            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_ghost"
                android:paddingHorizontal="20dp"
                style="@style/Text.14x.Manrope.Bold"
                android:text="Active"
                android:textAllCaps="false"
                android:textColor="#8c9a99"
                app:layout_constraintBottom_toBottomOf="@id/tvBasicPrice"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvBasicPrice" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_spark" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.12x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Plan"
                    android:textColor="#cfdad8" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Pro Plan -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardProPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="22dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_plan_card_active"
            android:padding="18dp"
            app:layout_constraintTop_toBottomOf="@id/cardBasicPlan">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvProTitle"
                style="@style/Text.20x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pro"
                android:textColor="@color/white"
                android:fontFamily="@font/manrope_extra_bold"
                app:fontFamily="@font/manrope_extra_bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvProDesc"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="230dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:lineSpacingExtra="4dp"
                android:text="Everything in Basic, plus AI insights, computed metrics, AI chat and personalised guidance."
                android:textColor="@color/white50"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProTitle" />

            <LinearLayout
                android:id="@+id/llProPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="bottom"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProDesc">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.24x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="£19.90"
                    android:textColor="@color/white"
                    android:textSize="26sp"
                    android:fontFamily="@font/manrope_extra_bold"
                    app:fontFamily="@font/manrope_extra_bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.12x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="/month"
                    android:textColor="@color/white50"
                    android:textSize="13sp"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_round_corner"
                android:backgroundTint="@color/lime_green"
                android:paddingHorizontal="20dp"
                style="@style/Text.14x.Manrope.Bold"
                android:text="View plan >"
                android:textAllCaps="false"
                android:textColor="@color/black"
                app:layout_constraintBottom_toBottomOf="@id/llProPrice"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/llProPrice" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_spark" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.10x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Plan"
                    android:textColor="#cfdad8" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvCategoryTitle"
            style="@style/Text.16x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginTop="22dp"
            android:text="@string/add_ons"
            android:textColor="#cdd6d5"
            android:fontFamily="@font/manrope_extra_bold"
            app:fontFamily="@font/manrope_extra_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardProPlan" />

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="12dp"
            app:shimmer_auto_start="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include layout="@layout/shimmer_shop_item" />
                <include layout="@layout/shimmer_shop_item" />
                <include layout="@layout/shimmer_shop_item" />
                <include layout="@layout/shimmer_shop_item" />

            </LinearLayout>

        </com.facebook.shimmer.ShimmerFrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTools"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingBottom="20dp"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryTitle"
            tools:listitem="@layout/item_shop_tool" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvNoData"
            style="@style/Text.16x.Manrope.SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_data_found"
            android:textColor="@color/white50"
            android:visibility="gone"
            android:layout_marginTop="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
