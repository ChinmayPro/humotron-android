<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@drawable/ic_bg_main_2"
    tools:context=".ui.device.DeviceDataFragment">

    <include
        android:id="@+id/header"
        layout="@layout/layout_header_3" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@android:color/transparent"
            app:elevation="0dp"
            tools:visibility="visible">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/_16dp"
                app:layout_scrollFlags="scroll|exitUntilCollapsed">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mcvDevice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_20dp"
                    app:cardBackgroundColor="#80070C0D"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <!-- Device Name -->
                        <TextView
                            android:id="@+id/tvDeviceName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Humotron Band"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@id/iconContainer"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Subtitle -->
                        <TextView
                            android:id="@+id/tvLastSyncTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Sync today"
                            android:textColor="#8C8C8C"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="@id/tvDeviceName"
                            app:layout_constraintTop_toBottomOf="@id/tvDeviceName" />

                        <!-- Icon Background -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/iconContainer"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cardBackgroundColor="@color/lime_14"
                            app:cardCornerRadius="16dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:strokeWidth="0dp">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivDevice"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                app:srcCompat="@drawable/ic_band_vectr"
                                app:tint="#A4FF39" />

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Take Reading Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTakeReading"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:layout_marginTop="24dp"
                            android:text="Take Reading"
                            android:textAllCaps="false"
                            android:textColor="@android:color/black"
                            android:textStyle="bold"
                            app:backgroundTint="@color/lime"
                            app:cornerRadius="26dp"
                            app:icon="@drawable/ic_decode_new"
                            app:iconPadding="10dp"
                            app:iconTint="@android:color/black"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvLastSyncTime" />

                        <!-- Alert Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAlert"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:backgroundTint="#0FFFFFFF"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            app:icon="@drawable/ic_device_notification"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="22dp"
                            app:iconTint="@color/white"
                            app:layout_constraintBottom_toBottomOf="@id/btnTakeReading"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/btnTakeReading"
                            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.Button.Circle"
                            app:strokeColor="@color/white10"
                            app:strokeWidth="1dp" />

                        <!-- Status Dot -->
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivDeviceStatus"
                            android:layout_width="@dimen/_7dp"
                            android:layout_height="@dimen/_7dp"
                            android:layout_marginTop="24dp"
                            android:src="@drawable/dot_disconnected"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/btnTakeReading" />

                        <!-- Connected -->
                        <TextView
                            android:id="@+id/tvDeviceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:includeFontPadding="false"
                            android:text="@string/disconnected"
                            android:textColor="@color/disconnected"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@id/ivDeviceStatus"
                            app:layout_constraintStart_toEndOf="@id/ivDeviceStatus"
                            app:layout_constraintTop_toTopOf="@id/ivDeviceStatus" />

                        <!-- Battery Progress -->
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressBattery"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="12dp"
                            android:max="100"
                            android:progress="30"
                            app:indicatorColor="@color/lime"
                            app:layout_constraintBottom_toBottomOf="@id/tvDeviceStatus"
                            app:layout_constraintEnd_toStartOf="@id/tvBatteryLevel"
                            app:layout_constraintStart_toEndOf="@id/tvDeviceStatus"
                            app:layout_constraintTop_toTopOf="@id/tvDeviceStatus"
                            app:trackColor="#1FFFFFFF"
                            app:trackCornerRadius="4dp"
                            app:trackStopIndicatorSize="0dp"
                            app:trackThickness="6dp" />

                        <!-- Battery % -->
                        <TextView
                            android:id="@+id/tvBatteryLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="@id/tvDeviceStatus"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tvDeviceStatus" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStaticContent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_16dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingEnd="@dimen/_20dp"
                    android:visibility="gone"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/mcvDevice"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_health_scan"
                    tools:visibility="gone" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_20dp"
                android:background="@color/pluto___transparent"
                app:tabGravity="start"
                app:tabIndicatorColor="@color/colorBgBtn"
                app:tabTextColor="@color/tab_text_selector">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/metrics" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights" />

            </com.google.android.material.tabs.TabLayout>

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/_30dp">

                <include
                    android:id="@+id/cl_tab_metrics"
                    layout="@layout/layout_tab_metrics" />

                <include
                    android:id="@+id/cl_tab_insights"
                    layout="@layout/layout_tab_insights"
                    android:visibility="gone" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</androidx.constraintlayout.widget.ConstraintLayout>