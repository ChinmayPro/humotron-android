<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/white" />

        <TextView
            style="@style/Text.16x.Manrope.Bold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/weather_resilience_report_title" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_info_24px"
            app:tint="@color/deep_dives_ink2" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvWeatherTitle"
        android:fontFamily="@font/manrope_bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:gravity="center"
                tools:text="HRV vs Temperature"
                android:textColor="@color/white"
                android:textSize="20sp"
            android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWeatherRange"
        android:fontFamily="@font/manrope_regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                tools:text="Feb 18 – Apr 08 · 180 paired days"
                android:textColor="@color/deep_dives_ink3"
                android:textSize="13sp" />

            <TextView
                style="@style/Text.11x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="22dp"
                android:letterSpacing="0.12"
                android:text="@string/label_summary"
                android:textColor="@color/insights_section_header_grey" />

            <TextView
                style="@style/Text.16x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="6dp"
                android:text="@string/label_weather_impact_summary" />

            <TextView
                android:id="@+id/tvWeatherSummary"
        android:fontFamily="@font/manrope_regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="6dp"
                tools:text="Your HRV thrives on cooler days. As temperatures climb, recovery isn't as strong — your body prefers a chillier environment to fully reset."
                android:textColor="@color/deep_dives_ink3"
                android:textSize="13sp" />

            <!-- Donut Chart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/bg_chart_wrap">

                <FrameLayout
                    android:layout_width="150dp"
                    android:layout_height="150dp">

                    <com.humotron.app.ui.decode.custom.DonutProgressView
                        android:id="@+id/donutProgress"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvImpactValue"
                            style="@style/Text.22x.Manrope.Bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="45%" />

                        <TextView
                            style="@style/Text.10x.Manrope.Regular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_impact"
                            android:textColor="@color/deep_dives_ink3" />
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvImpactNote"
                    android:fontFamily="@font/manrope_regular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    tools:text="Feels-like temperature has a moderate impact on your HRV."
                    android:textColor="@color/deep_dives_ink3"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                style="@style/Text.11x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="22dp"
                android:letterSpacing="0.12"
                android:text="@string/label_impact_level"
                android:textColor="@color/insights_section_header_grey" />

            <LinearLayout
                android:id="@+id/llImpactLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />

            <TextView
                style="@style/Text.11x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="22dp"
                android:letterSpacing="0.12"
                android:text="@string/label_trend"
                android:textColor="@color/insights_section_header_grey" />

            <TextView
                android:id="@+id/tvTrendTitle"
        android:fontFamily="@font/manrope_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="6dp"
                tools:text="HRV vs Feels like"
                android:textColor="@color/white"
                android:textSize="16sp"
            android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chart_wrap"
                android:padding="14dp">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartTrend"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>

            <!-- Insights Container -->
            <TextView
                style="@style/Text.11x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="22dp"
                android:letterSpacing="0.12"
                android:text="@string/label_key_insights"
                android:textColor="@color/insights_section_header_grey" />

            <LinearLayout
                android:id="@+id/llInsights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:orientation="vertical" />

            <!-- Plan Container -->
            <TextView
                style="@style/Text.11x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="22dp"
                android:letterSpacing="0.12"
                android:text="@string/label_recommended_plan"
                android:textColor="@color/insights_section_header_grey" />

            <LinearLayout
                android:id="@+id/llPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
