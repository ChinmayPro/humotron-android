<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@drawable/ic_bg_main"
    android:background="@drawable/ic_bg_main"
    tools:context=".ui.profile.ProfileFragment">

    <!-- Spacer to reserve room for the arrow button in collapsed state -->
    <android.widget.Space
        android:id="@+id/vHeaderSpace"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_50dp"
        app:layout_constraintTop_toBottomOf="@id/clConsole" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvProfile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/vHeaderSpace">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/_15dp"
            android:paddingTop="@dimen/_20dp"
            android:paddingBottom="@dimen/_30dp">

            <!-- Shop Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clShop"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginEnd="@dimen/_7dp"
                android:background="@drawable/bg_profile_grid_card"
                android:padding="@dimen/_18dp"
                app:layout_constraintEnd_toStartOf="@id/clOrder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivShop"
                    android:layout_width="@dimen/_30dp"
                    android:layout_height="@dimen/_30dp"
                    android:src="@drawable/ic_store"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:tint="@color/green_1" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.16x.Manrope.SemiBold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shop"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Order Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clOrder"
                android:layout_width="0dp"
                android:layout_height="@dimen/_100dp"
                android:layout_marginStart="@dimen/_7dp"
                android:background="@drawable/bg_profile_grid_card"
                android:padding="@dimen/_18dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/clShop"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivOrder"
                    android:layout_width="@dimen/_30dp"
                    android:layout_height="@dimen/_30dp"
                    android:src="@drawable/ic_track"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:tint="@color/green_1" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.16x.Manrope.SemiBold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/order"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Cart Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clCart"
                android:layout_width="0dp"
                android:layout_height="@dimen/_100dp"
                android:layout_marginTop="@dimen/_14dp"
                android:layout_marginEnd="@dimen/_7dp"
                android:background="@drawable/bg_profile_grid_card"
                android:padding="@dimen/_18dp"
                app:layout_constraintEnd_toStartOf="@id/clRecipes"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clShop">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivCart"
                    android:layout_width="@dimen/_30dp"
                    android:layout_height="@dimen/_30dp"
                    android:src="@drawable/ic_sync"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:tint="@color/green_1" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.16x.Manrope.SemiBold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cart"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Recipes Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clRecipes"
                android:layout_width="0dp"
                android:layout_height="@dimen/_100dp"
                android:layout_marginTop="@dimen/_14dp"
                android:layout_marginStart="@dimen/_7dp"
                android:background="@drawable/bg_profile_grid_card"
                android:padding="@dimen/_18dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/clCart"
                app:layout_constraintTop_toBottomOf="@id/clOrder">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivRecipes"
                    android:layout_width="@dimen/_30dp"
                    android:layout_height="@dimen/_30dp"
                    android:src="@drawable/ic_book_summary"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:tint="@color/green_1" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.16x.Manrope.SemiBold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recipes"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Profile Options List -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_20dp"
                android:paddingBottom="@dimen/_20dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/clCart">

                <!-- Privacy -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clPrivacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/_15dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        style="@style/Text.16x.Manrope.SemiBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/privacy"
                        android:textColor="@color/white_60"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/_20dp"
                        android:layout_height="@dimen/_20dp"
                        android:src="@drawable/ic_chevron_right_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white_60" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/assessment_unselect_stroke" />

                <!-- Support -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clSupport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/_15dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        style="@style/Text.16x.Manrope.SemiBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/support"
                        android:textColor="@color/white_60"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/_20dp"
                        android:layout_height="@dimen/_20dp"
                        android:src="@drawable/ic_chevron_right_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white_60" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/assessment_unselect_stroke" />

                <!-- FAQ -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clFaq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/_15dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        style="@style/Text.16x.Manrope.SemiBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/faq_label"
                        android:textColor="@color/white_60"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/_20dp"
                        android:layout_height="@dimen/_20dp"
                        android:src="@drawable/ic_chevron_right_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white_60" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/assessment_unselect_stroke" />

                <!-- Legal & Privacy Center -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clLegal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/_15dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        style="@style/Text.16x.Manrope.SemiBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/legal_privacy_center"
                        android:textColor="@color/white_60"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/_20dp"
                        android:layout_height="@dimen/_20dp"
                        android:src="@drawable/ic_chevron_right_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white_60" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/assessment_unselect_stroke" />

                <!-- Logout -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/_15dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        style="@style/Text.16x.Manrope.SemiBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/logout"
                        android:textColor="@color/white70"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/_20dp"
                        android:layout_height="@dimen/_20dp"
                        android:src="@drawable/ic_chevron_right_24px"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white50" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Console Background -->
    <View
        android:id="@+id/viewConsoleBg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_profile_console"
        app:layout_constraintBottom_toBottomOf="@id/llExpandGroup"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clConsole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/_10dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTitle"
            style="@style/Text.OnBoard.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20dp"
            android:text="@string/console"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:dividerColor="@color/_3B"
            android:layout_marginTop="@dimen/_10dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfile"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="@dimen/_20dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.Button.Circle" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvName"
            style="@style/Text.18x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10dp"
            tools:text="Name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivProfile" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvBadge"
            style="@style/Text.12x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10dp"
            android:background="@drawable/bg_badge_membership"
            android:paddingHorizontal="@dimen/_17dp"
            android:text="@string/basic"
            tools:text="Basic"
            android:textColor="@color/brown"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvName" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Expanded Content -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/clExpandedContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5dp"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/_15dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/clConsole">

        <!-- Active Plan Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clActivePlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_card"
            android:paddingStart="@dimen/_20dp"
            android:paddingEnd="@dimen/_15dp"
            android:paddingVertical="@dimen/_12dp">

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text.16x.Manrope.SemiBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/active_plan"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPlanBadge"
                style="@style/Text.12x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_membership"
                android:paddingHorizontal="@dimen/_17dp"
                android:layout_marginEnd="@dimen/_10dp"
                android:text="@string/basic"
                tools:text="Basic"
                android:textColor="@color/brown"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivPlanArrow"
                app:layout_constraintTop_toTopOf="parent"/>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivPlanArrow"
                android:layout_width="@dimen/_30dp"
                android:layout_height="@dimen/_30dp"
                android:src="@drawable/ic_arrow_right_begin"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/d600" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Add-Ons Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clAddOns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_18dp"
            android:background="@drawable/bg_profile_card"
            android:paddingStart="@dimen/_20dp"
            android:paddingEnd="@dimen/_15dp"
            android:paddingVertical="@dimen/_12dp">

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text.16x.Manrope.SemiBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_ons"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAddOnsStatus"
                style="@style/Text.14x.Manrope.SemiBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_10dp"
                android:text="@string/activated_count"
                tools:text="2 Activated"
                android:textColor="@color/green_1"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivAddOnsArrow"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivAddOnsArrow"
                android:layout_width="@dimen/_30dp"
                android:layout_height="@dimen/_30dp"
                android:src="@drawable/ic_arrow_right_begin"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/d600" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Manage Account -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvManageAccount"
            style="@style/Text.14x.Manrope.Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/_20dp"
            android:text="@string/manage_account"
            android:textColor="@color/white70" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/llExpandGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/_10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clExpandedContent">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivArrowDown"
            android:layout_width="@dimen/_20dp"
            android:layout_height="@dimen/_20dp"
            android:src="@drawable/ic_et_arrow_down"
            app:tint="@color/_3B" />

        <View
            android:id="@+id/viewDot"
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_dot_gray" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.constraintlayout.widget.ConstraintLayout>
