<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@drawable/ic_bg_main_2"
    tools:context=".ui.device.cuff.SmartCuffECGReadingFragment">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcvDeviceDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_14dp"
        app:cardBackgroundColor="@color/white10"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/_16dp"
            android:paddingVertical="@dimen/_14dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDeviceName"
                style="@style/Text.14x.Manrope.Bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_12dp"
                android:text="@string/humotron_smart_weight_scale"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivStatusDot"
                android:layout_width="@dimen/_7dp"
                android:layout_height="@dimen/_7dp"
                android:layout_marginTop="@dimen/_8dp"
                android:src="@drawable/dot_disconnected"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDeviceName" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDeviceStatus"
                style="@style/Text.10x.Manrope.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_6dp"
                android:text="@string/inactive"
                android:textColor="@color/disconnected"
                app:layout_constraintBottom_toBottomOf="@id/ivStatusDot"
                app:layout_constraintStart_toEndOf="@id/ivStatusDot"
                app:layout_constraintTop_toTopOf="@id/ivStatusDot" />

            <com.humotron.app.view.BatteryView
                android:id="@+id/batteryView"
                android:layout_width="@dimen/_20dp"
                android:layout_height="@dimen/_10dp"
                android:layout_marginEnd="@dimen/_5dp"
                app:layout_constraintBottom_toBottomOf="@+id/tvBatteryLevel"
                app:layout_constraintEnd_toStartOf="@+id/tvBatteryLevel"
                app:layout_constraintTop_toTopOf="@+id/tvBatteryLevel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvBatteryLevel"
                style="@style/Text.8x.Manrope.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textAlignment="center"
                app:layout_constraintBottom_toBottomOf="@+id/tvDeviceStatus"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tvDeviceStatus" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvMeasureTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_14dp"
        android:fontFamily="@font/manrope_bold"
        android:lineSpacingExtra="0dp"
        android:text="@string/please_remain_calm_and_still"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mcvDeviceDetails"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tvMeasureSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_5dp"
        android:fontFamily="@font/manrope_medium"
        android:text="@string/your_blood_pressure_measurement_is_in_progress"
        android:textColor="@color/ink2"
        android:textSize="14.5sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvMeasureTitle"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/ll_ecg_measure"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_14dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/tvMeasureSubtitle">

        <com.humotron.app.view.EcgWaveFormView
            android:id="@+id/ecgWaveformView"
            android:layout_width="match_parent"
            android:layout_height="194dp"
            android:contentDescription="@null"
            app:autoScale="true"
            app:backgroundColor="@color/black"
            app:baselineOffset="0dp"
            app:ecgCornerRadius="@dimen/_16dp"
            app:gridColor="@color/white10"
            app:gridGap="@dimen/_20dp"
            app:gridStrokeWidth="0.75dp"
            app:maxVisibleSamples="600"
            app:showBorder="true"
            app:showGrid="true"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="2dp"
            app:waveLineColor="@color/green_1"
            app:waveScale="0.85"
            app:waveStrokeWidth="2.5dp" />

        <TextView
            android:id="@+id/tvMeasureStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5dp"
            android:fontFamily="@font/manrope_bold"
            android:text="Capturing your heart rhythm"
            android:textColor="@color/ink2"
            android:textSize="14.5sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMeasureTitle"
            tools:visibility="visible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_18dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="@dimen/_12dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvEcgWaveformLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/ecg_waveform"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvEcgWaveformValue"
                    style="@style/Text.28x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8dp"
                    android:text="0"
                    android:textColor="@color/white" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvEcgWaveformUnit"
                    style="@style/Text.10x.Manrope.Regular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_2dp"
                    android:text="@string/millivolts_mv"
                    android:textColor="@color/ink3" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="@dimen/_12dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvPulseRateLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/pulse_rate"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvPulseRateValue"
                    style="@style/Text.28x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8dp"
                    android:text="0"
                    android:textColor="@color/white" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvPulseRateUnit"
                    style="@style/Text.10x.Manrope.Regular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_2dp"
                    android:text="@string/beats_per_minute"
                    android:textColor="@color/ink3" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_ecg_btns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20dp"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/gaugeBPView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/gaugeBPView"
            tools:visibility="visible">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSeeAllReadingsECG"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="@dimen/_22dp"
                android:paddingVertical="@dimen/_10dp"
                android:text="@string/see_all_reading"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@android:color/transparent"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.Button.Circle"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp" />

            <View
                android:layout_width="@dimen/_20dp"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetakeReadingsECG"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="@dimen/_22dp"
                android:paddingVertical="@dimen/_10dp"
                android:text="@string/retake_reading"
                android:textAllCaps="false"
                android:textColor="@color/black"
                app:backgroundTint="@color/colorBgBtn"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.Button.Circle"
                app:strokeWidth="0dp" />

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginBottom="10dp"
        android:fontFamily="@font/manrope_bold"
        android:text="@string/stop"
        android:textAllCaps="false"
        android:textColor="@color/ink3"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/transparent"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
