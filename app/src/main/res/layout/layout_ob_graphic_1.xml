<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="230dp"
        android:layout_height="230dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Center space anchor for circular constraint positioning -->
        <Space
            android:id="@+id/centerSpace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Radar animation custom view -->
        <com.humotron.app.ui.decode.view.RadarAnimationView
            android:id="@+id/radarView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 6 Label Pills around the radar -->
        <TextView
            android:id="@+id/tvHrv"
            style="@style/Text.10x.Manrope.SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights_processing_hrv"
            android:textColor="@color/insights_tag_grey"
            app:layout_constraintCircle="@id/centerSpace"
            app:layout_constraintCircleAngle="0"
            app:layout_constraintCircleRadius="81dp" />

        <TextView
            android:id="@+id/tvSleep"
            style="@style/Text.10x.Manrope.SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights_processing_sleep"
            android:textColor="@color/insights_tag_grey"
            app:layout_constraintCircle="@id/centerSpace"
            app:layout_constraintCircleAngle="60"
            app:layout_constraintCircleRadius="81dp" />

        <TextView
            android:id="@+id/tvTemp"
            style="@style/Text.10x.Manrope.SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights_processing_temp"
            android:textColor="@color/insights_tag_grey"
            app:layout_constraintCircle="@id/centerSpace"
            app:layout_constraintCircleAngle="120"
            app:layout_constraintCircleRadius="81dp" />

        <TextView
            android:id="@+id/tvGlucose"
            style="@style/Text.10x.Manrope.SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights_processing_glucose"
            android:textColor="@color/insights_tag_grey"
            app:layout_constraintCircle="@id/centerSpace"
            app:layout_constraintCircleAngle="180"
            app:layout_constraintCircleRadius="81dp" />

        <TextView
            android:id="@+id/tvSteps"
            style="@style/Text.10x.Manrope.SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights_processing_steps"
            android:textColor="@color/insights_tag_grey"
            app:layout_constraintCircle="@id/centerSpace"
            app:layout_constraintCircleAngle="240"
            app:layout_constraintCircleRadius="81dp" />

        <TextView
            android:id="@+id/tvStress"
            style="@style/Text.10x.Manrope.SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights_processing_stress"
            android:textColor="@color/insights_tag_grey"
            app:layout_constraintCircle="@id/centerSpace"
            app:layout_constraintCircleAngle="300"
            app:layout_constraintCircleRadius="81dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
