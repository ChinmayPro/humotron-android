<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@drawable/ic_bg_main_dark"
    tools:context=".ui.support.ContactSupportFragment">

    <include
        android:id="@+id/header"
        layout="@layout/layout_header_2"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/Text.22x.Manrope.Bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contact Support"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDescription"
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Briefly describe your issue or query, and our support team will get back to you."
                android:textColor="@color/white50"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSubjectLabel"
                style="@style/Text.14x.Manrope.SemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Subject"
                android:textColor="@color/white70"
                app:layout_constraintTop_toBottomOf="@id/tvDescription" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_et_login"
                android:fontFamily="@font/manrope_semibold"
                android:hint="Enter subject"
                android:includeFontPadding="false"
                android:inputType="text"
                android:minHeight="52dp"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/white30"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@id/tvSubjectLabel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvMessageLabel"
                style="@style/Text.14x.Manrope.SemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Message / Details"
                android:textColor="@color/white70"
                app:layout_constraintTop_toBottomOf="@id/etSubject" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_et_login"
                android:fontFamily="@font/manrope_semibold"
                android:hint="Describe your issue in detail"
                android:includeFontPadding="false"
                android:inputType="textMultiLine"
                android:minLines="5"
                android:gravity="top|start"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:textColor="@color/white"
                android:textColorHint="@color/white30"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@id/tvMessageLabel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:backgroundTint="@color/btn_continue"
                android:text="Submit Request"
                android:textColor="@color/btn_text_color"
                app:layout_constraintTop_toBottomOf="@id/etMessage" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
