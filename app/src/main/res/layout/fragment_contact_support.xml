<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:fitsSystemWindows="true"
    tools:background="@drawable/ic_bg_main_dark"
    tools:context=".ui.support.ContactSupportFragment">

    <include
        android:id="@+id/header"
        layout="@layout/layout_header_2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Fixed Top Header & Step Indicator -->
    <LinearLayout
        android:id="@+id/llTopContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Title & Subtitle -->
        <TextView
            android:id="@+id/tvSupportTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/contact_support_title"
            android:textAppearance="@style/Text.20x.Manrope.SemiBold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tvSupportSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="12dp"
            android:text="@string/contact_support_subtitle"
            android:textAppearance="@style/Text.14x.Manrope.Regular"
            android:textColor="@color/white50" />

        <!-- Step Indicator Container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clStepIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <!-- Guidelines representing center of 4 equal columns -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guide1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.125" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guide2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.375" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guide3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.625" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guide4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.875" />

            <!-- Column boundary Guidelines -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guide_col1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.25" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guide_col2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.50" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guide_col3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.75" />

            <!-- Circle 1 -->
            <TextView
                android:id="@+id/circle1"
                style="@style/Text.14x.Manrope.Bold"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_contact_step_active"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/colorBgBtn1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="@id/guide1"
                app:layout_constraintEnd_toEndOf="@id/guide1" />

            <!-- Circle 2 -->
            <TextView
                android:id="@+id/circle2"
                style="@style/Text.14x.Manrope.Bold"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_contact_radio_inactive"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/white30"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="@id/guide2"
                app:layout_constraintEnd_toEndOf="@id/guide2" />

            <!-- Circle 3 -->
            <TextView
                android:id="@+id/circle3"
                style="@style/Text.14x.Manrope.Bold"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_contact_radio_inactive"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/white30"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="@id/guide3"
                app:layout_constraintEnd_toEndOf="@id/guide3" />

            <!-- Circle 4 -->
            <TextView
                android:id="@+id/circle4"
                style="@style/Text.14x.Manrope.Bold"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_contact_radio_inactive"
                android:gravity="center"
                android:text="4"
                android:textColor="@color/white30"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="@id/guide4"
                app:layout_constraintEnd_toEndOf="@id/guide4" />

            <!-- Line 1: Circle 1 to Circle 2 -->
            <View
                android:id="@+id/line1"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="@color/white10"
                app:layout_constraintTop_toTopOf="@id/circle1"
                app:layout_constraintBottom_toBottomOf="@id/circle1"
                app:layout_constraintStart_toEndOf="@id/circle1"
                app:layout_constraintEnd_toStartOf="@id/circle2" />

            <!-- Line 2: Circle 2 to Circle 3 -->
            <View
                android:id="@+id/line2"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="@color/white10"
                app:layout_constraintTop_toTopOf="@id/circle1"
                app:layout_constraintBottom_toBottomOf="@id/circle1"
                app:layout_constraintStart_toEndOf="@id/circle2"
                app:layout_constraintEnd_toStartOf="@id/circle3" />

            <!-- Line 3: Circle 3 to Circle 4 -->
            <View
                android:id="@+id/line3"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="@color/white10"
                app:layout_constraintTop_toTopOf="@id/circle1"
                app:layout_constraintBottom_toBottomOf="@id/circle1"
                app:layout_constraintStart_toEndOf="@id/circle3"
                app:layout_constraintEnd_toStartOf="@id/circle4" />

            <!-- Label 1 -->
            <TextView
                android:id="@+id/tvLabel1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/contact_step_issue_details"
                android:textAppearance="@style/Text.12x.Manrope.Regular"
                android:textColor="@color/colorBgBtn1"
                app:layout_constraintTop_toBottomOf="@id/circle1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/guide_col1" />

            <!-- Label 2 -->
            <TextView
                android:id="@+id/tvLabel2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/contact_step_more_info"
                android:textAppearance="@style/Text.12x.Manrope.Regular"
                android:textColor="@color/white30"
                app:layout_constraintTop_toBottomOf="@id/circle2"
                app:layout_constraintStart_toStartOf="@id/guide_col1"
                app:layout_constraintEnd_toStartOf="@id/guide_col2" />

            <!-- Label 3 -->
            <TextView
                android:id="@+id/tvLabel3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/contact_step_attachments"
                android:textAppearance="@style/Text.12x.Manrope.Regular"
                android:textColor="@color/white30"
                app:layout_constraintTop_toBottomOf="@id/circle3"
                app:layout_constraintStart_toStartOf="@id/guide_col2"
                app:layout_constraintEnd_toStartOf="@id/guide_col3" />

            <!-- Label 4 -->
            <TextView
                android:id="@+id/tvLabel4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/contact_step_review"
                android:textAppearance="@style/Text.12x.Manrope.Regular"
                android:textColor="@color/white30"
                app:layout_constraintTop_toBottomOf="@id/circle4"
                app:layout_constraintStart_toStartOf="@id/guide_col3"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/llTopContainer"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- Section 1 -->
            <TextView
                android:id="@+id/tvSection1Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/contact_what_help"
                android:textAppearance="@style/Text.16x.Manrope.SemiBold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvSection1Subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/contact_select_option"
                android:textAppearance="@style/Text.14x.Manrope.Regular"
                android:textColor="@color/white50" />

            <!-- Category Container -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_contact_category" />

            <!-- Section 2 -->
            <TextView
                android:id="@+id/tvSection2Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/contact_describe_issue"
                android:textAppearance="@style/Text.16x.Manrope.SemiBold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvSection2Subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/contact_describe_subtitle"
                android:textAppearance="@style/Text.14x.Manrope.Regular"
                android:textColor="@color/white50" />

            <!-- Description Input Area -->
            <LinearLayout
                android:id="@+id/llDescriptionInputContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_contact_description_input"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:gravity="top|start"
                    android:hint="@string/contact_describe_hint"
                    android:maxLength="1000"
                    android:minLines="5"
                    android:textAppearance="@style/Text.14x.Manrope.Regular"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white30"
                    android:importantForAutofill="no"
                    android:inputType="textMultiLine" />

                <TextView
                    android:id="@+id/tvCharCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:text="0/1000"
                    android:textAppearance="@style/Text.12x.Manrope.Regular"
                    android:textColor="@color/white30" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Step 2 (More information) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewStep2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/llTopContainer"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- Title & Subtitle -->
            <TextView
                android:id="@+id/tvStep2Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/contact_step2_title"
                android:textAppearance="@style/Text.18x.Manrope.SemiBold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvStep2Subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/contact_step2_subtitle"
                android:textAppearance="@style/Text.14x.Manrope.Regular"
                android:textColor="@color/white50" />

            <!-- Device Selector -->
            <TextView
                android:id="@+id/tvDeviceTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/contact_select_device_title"
                android:textAppearance="@style/Text.16x.Manrope.SemiBold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvDeviceDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/contact_select_device_desc"
                android:textAppearance="@style/Text.14x.Manrope.Regular"
                android:textColor="@color/white50" />

            <RelativeLayout
                android:id="@+id/rlDeviceSelector"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_contact_description_input"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/ivSelectedDeviceIcon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvSelectedDevice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/ivSelectedDeviceIcon"
                    android:text="Select a device"
                    android:textAppearance="@style/Text.14x.Manrope.Regular"
                    android:textColor="@color/white50" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_keyboard_arrow_down_24px"
                    app:tint="@color/white" />
            </RelativeLayout>

            <!-- Issue/Problem Selector -->
            <TextView
                android:id="@+id/tvProblemTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/contact_problem_title"
                android:textAppearance="@style/Text.18x.Manrope.SemiBold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvProblemDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/contact_problem_desc"
                android:textAppearance="@style/Text.14x.Manrope.Regular"
                android:textColor="@color/white50" />

            <RelativeLayout
                android:id="@+id/rlProblemSelector"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_contact_description_input"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/tvSelectedProblem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Select an issue"
                    android:textAppearance="@style/Text.14x.Manrope.Regular"
                    android:textColor="@color/white50" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_keyboard_arrow_down_24px"
                    app:tint="@color/white" />
            </RelativeLayout>

            <!-- When did this start? Selection -->
            <TextView
                android:id="@+id/tvStartTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/contact_start_title"
                android:textAppearance="@style/Text.16x.Manrope.SemiBold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvStartDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/contact_start_desc"
                android:textAppearance="@style/Text.14x.Manrope.Regular"
                android:textColor="@color/white50" />

            <RadioGroup
                android:id="@+id/rgStartDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_contact_description_input"
                android:padding="2dp">

                <RadioButton
                    android:id="@+id/rbToday"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:button="@null"
                    android:checked="true"
                    android:drawableEnd="@drawable/selector_contact_radio"
                    android:text="Today"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/support_search_border" />

                <RadioButton
                    android:id="@+id/rbLast7Days"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_contact_radio"
                    android:text="In the last 7 days"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/support_search_border" />

                <RadioButton
                    android:id="@+id/rbLast30Days"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_contact_radio"
                    android:text="In the last 30 days"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/support_search_border" />

                <RadioButton
                    android:id="@+id/rbMoreThan30Days"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_contact_radio"
                    android:text="More than 30 days ago"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/support_search_border" />

                <RadioButton
                    android:id="@+id/rbNotSure"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_contact_radio"
                    android:text="Not sure"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical" />
            </RadioGroup>

            <!-- App Version selection -->
            <TextView
                android:id="@+id/tvAppVersionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/contact_app_version_title"
                android:textAppearance="@style/Text.16x.Manrope.SemiBold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvAppVersionDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/contact_app_version_desc"
                android:textAppearance="@style/Text.14x.Manrope.Regular"
                android:textColor="@color/white50" />

            <RelativeLayout
                android:id="@+id/rlAppVersionSelector"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_contact_description_input"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/tvSelectedAppVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="1.0.1 (55)"
                    android:textAppearance="@style/Text.14x.Manrope.Regular"
                    android:textColor="@color/white" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_keyboard_arrow_down_24px"
                    app:tint="@color/white" />
            </RelativeLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Step 1 Button Container -->
        <FrameLayout
            android:id="@+id/flStep1Buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_btn_round_rect_16"
                android:fontFamily="@font/manrope_bold"
                android:text="@string/contact_continue"
                android:textAllCaps="false"
                android:textColor="@color/d900"
                android:textSize="16sp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/colorBgBtn1" />
        </FrameLayout>

        <!-- Step 2 Button Container -->
        <LinearLayout
            android:id="@+id/llStep2Buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBackStep2"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_btn_back_step2"
