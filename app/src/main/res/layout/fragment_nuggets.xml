<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    tools:background="@color/black"
    tools:context=".ui.bioHack.NuggetsFragment">

    <include
        android:id="@+id/header"
        layout="@layout/layout_header_biohack"
        app:layout_constraintTop_toTopOf="parent" />


    <com.yuyakaido.android.cardstackview.CardStackView
        android:id="@+id/card_stack_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_10dp"
        android:layout_marginBottom="@dimen/_60dp"
        android:clipToPadding="false"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivDisLike"
        android:layout_width="@dimen/_60dp"
        android:layout_height="@dimen/_60dp"
        android:layout_marginStart="@dimen/_15dp"
        android:background="@drawable/bg_round_green"
        android:backgroundTint="@color/_1f"
        android:padding="@dimen/_18dp"
        android:src="@drawable/ic_dislike"
        app:layout_constraintBottom_toBottomOf="@id/card_stack_view"
        app:layout_constraintEnd_toStartOf="@id/ivLike"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_stack_view" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivLike"
        android:layout_width="@dimen/_60dp"
        android:layout_height="@dimen/_60dp"
        android:background="@drawable/bg_round_green"
        android:backgroundTint="@color/_1f"
        android:padding="@dimen/_18dp"
        android:src="@drawable/ic_like"
        app:layout_constraintEnd_toStartOf="@id/ivBookMark"
        app:layout_constraintStart_toEndOf="@id/ivDisLike"
        app:layout_constraintTop_toTopOf="@id/ivDisLike" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivBookMark"
        android:layout_width="@dimen/_60dp"
        android:layout_height="@dimen/_60dp"
        android:background="@drawable/bg_round_green"
        android:backgroundTint="@color/_1f"
        android:padding="@dimen/_18dp"
        android:src="@drawable/ic_bookmark"
        app:layout_constraintEnd_toStartOf="@id/ivDetail"
        app:layout_constraintStart_toEndOf="@id/ivLike"
        app:layout_constraintTop_toTopOf="@id/ivDisLike" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivDetail"
        android:layout_width="@dimen/_60dp"
        android:layout_height="@dimen/_60dp"
        android:layout_marginEnd="@dimen/_15dp"
        android:background="@drawable/bg_round_green"
        android:backgroundTint="@color/_1f"
        android:padding="@dimen/_18dp"
        android:src="@drawable/ic_detail"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toEndOf="@id/ivBookMark"
        app:layout_constraintTop_toTopOf="@id/ivDisLike" />


</androidx.constraintlayout.widget.ConstraintLayout>