<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="22dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#132123"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#12FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            tools:text="Comprehensive Full Body Checkup" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvOrderNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/manrope_medium"
            android:textColor="#8ea09e"
            android:textSize="12sp"
            tools:text="#793599044 · Self-collection kit" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="#12FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="14dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSubTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="#cfdad8"
                android:textSize="13sp"
                tools:text="113 Masthead House, 14 Rope Terrace, London E16 2PH" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAppointmentDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/manrope_bold"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:text="18 Jun 2026 · 12:26" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#12FFFFFF" />

        <LinearLayout
            android:id="@+id/llAddToCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_appointment_followup"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_appointments"
                app:tint="#C4F23E" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAddToCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/manrope_semibold"
                android:text="Add to calendar"
                android:textColor="#cfdad8"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvReschedule"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4.5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_appointment_trk_btn"
                android:fontFamily="@font/manrope_bold"
                android:gravity="center"
                android:paddingVertical="11dp"
                android:text="Reschedule"
                android:textColor="#dfe9e3"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4.5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_appointment_trk_btn"
                android:fontFamily="@font/manrope_bold"
                android:gravity="center"
                android:paddingVertical="11dp"
                android:text="Cancel"
                android:textColor="#dfe9e3"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Keep missing ids as gone -->
        <View android:id="@+id/ivBookingIcon" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/ivCall" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/ivMessage" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/ivLocation" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/btnJoinHere" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tvBookingDate" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tvBookingDetailsLabel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tvPrepare" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
