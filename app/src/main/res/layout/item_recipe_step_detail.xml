<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:orientation="horizontal"
    android:gravity="top">

    <TextView
        android:id="@+id/tvStepNumber"
        style="@style/Text.12x.Manrope.Bold"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:background="@drawable/circle_white"
        android:backgroundTint="#14FFFFFF"
        android:gravity="center"
        android:textColor="@color/white"
        tools:text="1" />

    <TextView
        android:id="@+id/tvStepText"
        style="@style/Text.12_5x.Manrope.Medium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/textColorDesc"
        tools:text="Sauté the kale with garlic until just wilted." />
</LinearLayout>
