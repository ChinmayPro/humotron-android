<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.profile.ManageAccountFragment">

    <!-- Header -->
    <include
        android:id="@+id/layoutHeader"
        layout="@layout/layout_header_2"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- Profile Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profcard"
                android:paddingVertical="32dp"
                android:paddingHorizontal="24dp">

                <FrameLayout
                    android:id="@+id/clAvatarContainer"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- Gradient/Stroke Monogram Circle -->
                    <View
                        android:id="@+id/viewAvatarMonogram"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_monogram" />

                    <!-- Monogram Initial Text -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvAvatarInitials"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/manrope_extra_bold"
                        android:textSize="36sp"
                        android:textColor="@color/lime"
                        android:textStyle="bold"
                        android:letterSpacing="-0.03"
                        tools:text="C" />

                    <!-- Optional User Image Profile (overlays text and bg if loaded) -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivAvatarBg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.Button.Circle"
                        tools:visibility="visible" />
                </FrameLayout>


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvName"
                    style="@style/Text.20x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Chinmay Bhatt"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/clAvatarContainer" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/btnEditDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_edit_details_btn"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="10dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvName">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_edit"
                        app:tint="#0d1618" />

                    <androidx.appcompat.widget.AppCompatTextView
                        style="@style/Text.14x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Edit details"
                        android:textColor="#0d1618"
                        android:fontFamily="@font/manrope_bold"
                        app:fontFamily="@font/manrope_bold" />
                </androidx.appcompat.widget.LinearLayoutCompat>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Personal Info Section -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.12x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.08"
                    android:text="PERSONAL INFO"
                    android:textColor="@color/white_60"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="#14FFFFFF" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Gender -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_config_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gender"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvGender"
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Male"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Birthdate -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_config_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Birthdate"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvBirthdate"
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24 Aug 1984"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Height -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_config_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Height"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvHeight"
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="180 cm"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Weight -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_config_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Weight"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvWeight"
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="74 kg"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Country -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_config_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Country"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCountry"
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="United Kingdom"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Account Section -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.12x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.08"
                    android:text="ACCOUNT"
                    android:textColor="@color/white_60"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="#14FFFFFF" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Email -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_config_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Email"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvEmail"
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="chinmay@humotron.com"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Password -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_config_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Password"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvPassword"
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• • • • • •"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    app:fontFamily="@font/manrope_bold" />
            </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

