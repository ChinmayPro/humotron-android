<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_uploaded_report_card"
    android:clipToOutline="true">

    <!-- Top Details Skeleton -->
    <View
        android:id="@+id/vReading"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:layout_marginStart="@dimen/_10dp"
        android:layout_marginTop="@dimen/_10dp"
        android:background="@color/white10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/vName"
        android:layout_width="120dp"
        android:layout_height="20dp"
        android:layout_marginTop="@dimen/_8dp"
        android:background="@color/white10"
        app:layout_constraintStart_toStartOf="@+id/vReading"
        app:layout_constraintTop_toBottomOf="@+id/vReading" />

    <View
        android:id="@+id/vDesc"
        android:layout_width="100dp"
        android:layout_height="18dp"
        android:layout_marginTop="@dimen/_4dp"
        android:background="@color/white10"
        app:layout_constraintStart_toStartOf="@+id/vName"
        app:layout_constraintTop_toBottomOf="@+id/vName" />

    <!-- Indicators Skeleton -->
    <View
        android:id="@+id/vIconL"
        android:layout_width="@dimen/_15dp"
        android:layout_height="@dimen/_15dp"
        android:layout_marginTop="@dimen/_10dp"
        android:background="@color/white10"
        app:layout_constraintStart_toStartOf="@+id/vDesc"
        app:layout_constraintTop_toBottomOf="@+id/vDesc" />

    <View
        android:id="@+id/vIconR"
        android:layout_width="@dimen/_15dp"
        android:layout_height="@dimen/_15dp"
        android:layout_marginEnd="@dimen/_10dp"
        android:background="@color/white10"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/vIconL" />

    <!-- Bottom Section Background -->
    <View
        android:layout_width="0dp"
        android:layout_height="@dimen/_90dp"
        android:layout_marginTop="@dimen/_10dp"
        android:layout_marginStart="@dimen/_1dp"
        android:layout_marginEnd="@dimen/_1dp"
        android:layout_marginBottom="@dimen/_1dp"
        android:background="@drawable/bg_key_reading_footer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/vIconL" />

</androidx.constraintlayout.widget.ConstraintLayout>
