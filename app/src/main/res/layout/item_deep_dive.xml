<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/_30dp"
    tools:background="@color/black50">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/black"
        android:layout_marginHorizontal="@dimen/_24dp"
        app:strokeWidth="0dp"
        app:cardCornerRadius="@dimen/_12dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/_18dp"
            android:paddingVertical="@dimen/_20dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/Text.18x.Manrope.SemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/textColorPink"
                tools:text="The Science of Cellular Health" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSubTitle"
                style="@style/Text.12x.Manrope.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10dp"
                android:textColor="@color/_97"
                tools:text="The Science of Cellular Health" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvContent"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_15dp"
                android:textColor="@color/textColorWhite"
                tools:text="The Science of Cellular Health" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/tvTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_22dp"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_17dp"
                    android:layout_height="@dimen/_17dp"
                    android:src="@drawable/ic_tags" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvSource"
                    style="@style/Text.14x.Manrope.Regular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_10dp"
                    android:text="Dopamine Nation - Anna Lembke"
                    android:textColor="@color/d400" />


            </androidx.appcompat.widget.LinearLayoutCompat>


        </androidx.appcompat.widget.LinearLayoutCompat>


    </com.google.android.material.card.MaterialCardView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_15dp"
        android:paddingHorizontal="@dimen/_24dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/card">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPrompt1"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_prompt"
                android:drawableStart="@drawable/ic_prompt_star"
                android:drawablePadding="@dimen/_8dp"
                android:paddingHorizontal="@dimen/_8dp"
                android:paddingVertical="@dimen/_13dp"
                android:textColor="@color/textColorWhite"
                tools:text="Deep Dives" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPrompt2"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_prompt"
                android:layout_marginStart="@dimen/_8dp"
                android:drawableStart="@drawable/ic_prompt_star"
                android:drawablePadding="@dimen/_8dp"
                android:paddingHorizontal="@dimen/_8dp"
                android:paddingVertical="@dimen/_13dp"
                android:textColor="@color/textColorWhite"
                tools:text="Deep Dives" />


        </androidx.appcompat.widget.LinearLayoutCompat>


    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>