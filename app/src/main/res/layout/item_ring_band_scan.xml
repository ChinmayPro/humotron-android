<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/_16dp"
    app:cardBackgroundColor="@color/take_reading_card_bg_soft"
    app:cardCornerRadius="@dimen/_20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/viewAccent"
            android:layout_width="@dimen/_4dp"
            android:layout_height="0dp"
            android:background="@color/series"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconContainer"
            android:layout_width="@dimen/_40dp"
            android:layout_height="@dimen/_40dp"
            android:layout_marginStart="@dimen/_16dp"
            android:layout_marginTop="@dimen/_18dp"
            app:cardBackgroundColor="@color/take_reading_icon_bg"
            app:cardCornerRadius="@dimen/_14dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toEndOf="@id/viewAccent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivScan"
                android:layout_width="@dimen/_18dp"
                android:layout_height="@dimen/_18dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/ic_metrics_heart"
                app:tint="@color/series" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvScanTitle"
            style="@style/Text.16x.Manrope.Bold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_12dp"
            android:layout_marginTop="@dimen/_18dp"
            android:layout_marginEnd="@dimen/_16dp"
            android:includeFontPadding="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="@string/take_reading_stress_scan_title" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvScanSubtitle"
            style="@style/Text.13x.Manrope.Regular"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_12dp"
            android:layout_marginTop="@dimen/_4dp"
            android:layout_marginEnd="@dimen/_16dp"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/ink3"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintTop_toBottomOf="@id/tvScanTitle"
            tools:text="@string/take_reading_stress_scan_subtitle" />

        <View
            android:id="@+id/viewDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/_16dp"
            android:background="@color/take_reading_card_stroke"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/iconContainer"
            app:layout_constraintTop_toBottomOf="@id/tvScanSubtitle" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/_14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/viewDivider"
            app:layout_constraintTop_toBottomOf="@id/viewDivider">

            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="@dimen/_8dp"
                android:layout_height="@dimen/_8dp"
                android:background="@drawable/bg_take_reading_chip" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvLastLabel"
                style="@style/Text.12x.Manrope.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_8dp"
                android:includeFontPadding="false"
                android:textColor="@color/ink3"
                android:textSize="12sp"
                tools:text="@string/take_reading_last_label" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvLastValue"
                style="@style/Text.12x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_4dp"
                android:includeFontPadding="false"
                android:textColor="@color/good"
                android:textSize="12sp"
                app:layout_constraintBaseline_toBaselineOf="@id/viewStatusDot"
                app:layout_constraintStart_toEndOf="@id/tvLastLabel"
                tools:text="@string/balanced" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvLastDate"
                style="@style/Text.12x.Manrope.Medium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_4dp"
                android:layout_weight="1"
                android:includeFontPadding="false"
                android:textColor="@color/ink3"
                android:textSize="12sp"
                app:layout_constraintBaseline_toBaselineOf="@id/viewStatusDot"
                app:layout_constraintStart_toEndOf="@id/tvLastValue"
                tools:text="· 23 Jun" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvScanNow"
                style="@style/Text.13x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_8dp"
                android:includeFontPadding="false"
                android:text="@string/take_reading_scan_now_label"
                android:textColor="@color/take_reading_scan_accent"
                android:textSize="13sp"
                app:layout_constraintBaseline_toBaselineOf="@id/viewStatusDot"
                app:layout_constraintEnd_toStartOf="@id/ivChevron"
                app:layout_constraintTop_toBottomOf="@id/viewDivider" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivChevron"
                android:layout_width="@dimen/_14dp"
                android:layout_height="@dimen/_14dp"
                android:layout_marginEnd="@dimen/_16dp"
                app:layout_constraintBaseline_toBaselineOf="@id/tvScanNow"
                app:layout_constraintEnd_toEndOf="parent"
                app:srcCompat="@drawable/ic_metrics_chevron_right"
                app:tint="@color/take_reading_scan_accent" />

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="@dimen/_18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>