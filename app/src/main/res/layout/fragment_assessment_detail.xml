<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include
        android:id="@+id/header"
        layout="@layout/layout_header_left"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_56dp"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="14dp">

            <!-- Source Card Group (.srcgroup) -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:background="@drawable/bg_source_group"
                android:orientation="horizontal"
                android:padding="16dp">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/llDeviceIcon"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:gravity="center"
                    android:background="@drawable/bg_rounded_12"
                    android:backgroundTint="#265FB7C4">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivDeviceIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_menu_24px"
                        app:tint="#5FB7C4" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Lifestyle Assessment"
                        android:textColor="#FFFFFF"
                        android:textSize="14.5sp"
                        app:fontFamily="@font/manrope_bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvDeviceDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_regular"
                        android:text="Diet, sleep, activity &amp; habits"
                        android:textColor="#859390"
                        android:textSize="11.5sp"
                        app:fontFamily="@font/manrope_regular" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Status Badge Pill (.anonpill) -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="13dp"
                android:background="@drawable/bg_anon_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="13dp"
                android:paddingVertical="8dp">

                <View
                    android:id="@+id/vStatusDot"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:background="@drawable/bg_status_dot_with_shadow" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:fontFamily="@font/manrope_bold"
                    android:textStyle="bold"
                    android:text="Updated 12 Jun"
                    android:textColor="#cfdad8"
                    android:textSize="12sp"
                    app:fontFamily="@font/manrope_bold" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Assure bar for answers -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_source_group"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_lock_outline"
                    app:tint="#7BD88F" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvAssureText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/manrope_regular"
                    android:lineSpacingMultiplier="1.2"
                    android:text="These are your answers. You decide how much of them we analyse — pause the whole assessment, or hold back individual questions."
                    android:textColor="#dfe9e3"
                    android:textSize="12.5sp"
                    app:fontFamily="@font/manrope_regular" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Use in Analysis Section -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:textStyle="bold"
                android:text="Use in analysis"
                android:textColor="#FFFFFF"
                android:textSize="16.5sp"
                app:fontFamily="@font/manrope_extra_bold" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/manrope_regular"
                android:text="Pause to stop this assessment feeding your insights."
                android:textColor="#859390"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <!-- Use in Analysis Card -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_cfg_card"
                android:orientation="vertical">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="15dp">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switchInclude"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:textStyle="bold"
                            android:text="Include in analysis"
                            android:textColor="#FFFFFF"
                            android:textSize="15.5sp"
                            app:fontFamily="@font/manrope_bold" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/manrope_regular"
                            android:text="Syncing into insights, chat &amp; suggestions"
                            android:textColor="#6F7E7D"
                            android:textSize="11.5sp"
                            app:fontFamily="@font/manrope_regular" />
                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchInclude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Exclude Individual Questions Section -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:textStyle="bold"
                android:text="Exclude individual questions"
                android:textColor="#FFFFFF"
                android:textSize="16.5sp"
                app:fontFamily="@font/manrope_extra_bold" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/manrope_regular"
                android:text="Toggle off anything you'd rather we didn't read."
                android:textColor="#859390"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <!-- Exclude Individual Questions Card Container -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llQuestionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_cfg_card"
                android:orientation="vertical" />

            <!-- Manage Section -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:textStyle="bold"
                android:text="Manage"
                android:textColor="#FFFFFF"
                android:textSize="16.5sp"
                app:fontFamily="@font/manrope_extra_bold" />

            <!-- Edit your answers row -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llEditAnswers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_ctrl_row"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_ctrl_icon_box"
                    android:gravity="center">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_edit"
                        app:tint="#C4F23E" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Edit your answers"
                        android:textColor="#FFFFFF"
                        android:textSize="15.5sp"
                        app:fontFamily="@font/manrope_bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_regular"
                        android:text="Update this assessment in your profile"
                        android:textColor="#6F7E7D"
                        android:textSize="11.5sp"
                        app:fontFamily="@font/manrope_regular" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right_24px"
                    app:tint="#6E837F" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Pause Assessment Row -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llPauseAssessment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_ctrl_row"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_ctrl_icon_box"
                    android:gravity="center">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_alarm_24px"
                        app:tint="#E7A93C" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Pause this assessment"
                        android:textColor="#FFFFFF"
                        android:textSize="15.5sp"
                        app:fontFamily="@font/manrope_bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvPauseDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_regular"
                        android:text="Temporarily exclude all answers"
                        android:textColor="#6F7E7D"
                        android:textSize="11.5sp"
                        app:fontFamily="@font/manrope_regular" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Delete All Data Row -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llDeleteAssessment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_ctrl_row"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_ctrl_icon_box"
                    android:gravity="center">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_delete"
                        app:tint="#F0795E" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Delete all data"
                        android:textColor="#F0795E"
                        android:textSize="15.5sp"
                        app:fontFamily="@font/manrope_bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_regular"
                        android:text="Permanently remove your answers"
                        android:textColor="#6F7E7D"
                        android:textSize="11.5sp"
                        app:fontFamily="@font/manrope_regular" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
