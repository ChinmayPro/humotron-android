<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#8C080F10"
        app:cardCornerRadius="20dp"
        app:strokeColor="#12FFFFFF"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Category / Eyebrow Label -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvCategory"
                style="@style/Text.10x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#73827F"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="SUPPLEMENT" />

            <!-- Metric Pill -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clMetricPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_metric_pill_capsule"
                android:paddingHorizontal="11dp"
                android:paddingVertical="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Status Dot -->
                <View
                    android:id="@+id/vStatusDot"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/bg_round_green"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Metric Name -->
                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvMetricName"
                    style="@style/Text.12x.Manrope.SemiBold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/textColorMuted"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/vStatusDot"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="HRV" />

                <!-- Metric Delta -->
                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvMetricDelta"
                    style="@style/Text.12x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="monospace"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvMetricName"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:textColor="#EE4D3D"
                    tools:text="↓ 28%" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Title & Chevron Row -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/Text.16x.Manrope.Bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:layout_marginEnd="10dp"
                android:textColor="@color/white"
                app:layout_constraintEnd_toStartOf="@id/ivChevron"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvCategory"
                tools:text="Magnesium Glycinate 400mg" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivChevron"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_chevron_right_24px"
                app:layout_constraintBottom_toBottomOf="@id/tvTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvTitle"
                app:tint="@color/textColorMuted" />

            <!-- Description -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvShort"
                style="@style/Text.13x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#859390"
                android:lineSpacingExtra="3dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                tools:text="Calms the nervous system and eases your overnight heart rate." />

            <!-- Confidence Badge -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvBadge"
                style="@style/Text.10x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:background="@drawable/bg_badge_high"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="@color/colorBgBtn"
                android:letterSpacing="0.04"
                android:textAllCaps="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvShort"
                tools:text="High Confidence" />

            <!-- Rationale Section (Collapsible) -->
            <LinearLayout
                android:id="@+id/clExpandedSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvBadge"
                tools:visibility="visible">

                <!-- Divider 1 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#12FFFFFF" />

                <!-- Why This Row -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="7dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvWhyThisLabel"
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="68dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorBgBtn"
                        android:textAllCaps="true"
                        android:letterSpacing="0.04"
                        android:text="Why this"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvWhyThisContent"
                        style="@style/Text.12x.Manrope.Regular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="#CFD8D7"
                        android:lineSpacingExtra="2dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvWhyThisLabel"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Glycinate is the best-tolerated, best-absorbed form for sleep and recovery." />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Divider 2 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#12FFFFFF" />

                <!-- Why You Row -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="7dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvWhyYouLabel"
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="68dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorBgBtn"
                        android:textAllCaps="true"
                        android:letterSpacing="0.04"
                        android:text="Why you"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvWhyYouContent"
                        style="@style/Text.12x.Manrope.Regular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="#CFD8D7"
                        android:lineSpacingExtra="2dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvWhyYouLabel"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Your low HRV and shorter deep sleep point to a system not downshifting at night." />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Divider 3 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#12FFFFFF" />

                <!-- Why Now Row -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="7dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvWhyNowLabel"
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="68dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorBgBtn"
                        android:textAllCaps="true"
                        android:letterSpacing="0.04"
                        android:text="Why now"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvWhyNowContent"
                        style="@style/Text.12x.Manrope.Regular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="#CFD8D7"
                        android:lineSpacingExtra="2dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvWhyNowLabel"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Three nights of reduced deep sleep — the window where this helps most." />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- View Product Details Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnViewDetails"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_btn_view_details"
                    android:text="View product details  →"
                    android:textAllCaps="false"
                    android:textColor="@color/colorBgBtn"
                    style="@style/Text.14x.Manrope.Bold" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
