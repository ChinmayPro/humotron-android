<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:background="@drawable/ic_bg_main"
    tools:context=".ui.onboarding.personalize.PersonalInfoFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTitle"
            style="@style/Text.OnBoard.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_24dp"
            android:layout_marginTop="@dimen/_50dp"
            android:text="@string/lets_get_started"
            android:textSize="27sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSubtitle"
            style="@style/Text.OnBoard.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_6dp"
            android:paddingStart="@dimen/_24dp"
            android:paddingEnd="@dimen/_48dp"
            android:text="@string/personalize_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />


        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20dp"
            android:layout_marginTop="@dimen/_44dp"
            android:background="@drawable/bg_et_login"
            android:fontFamily="@font/manrope_semibold"
            android:hint="@string/name"
            android:includeFontPadding="false"
            android:minHeight="52dp"
            android:paddingHorizontal="@dimen/_24dp"
            android:textColor="@color/white"
            android:textColorHint="@color/white70"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />


        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etBirthday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20dp"
            android:layout_marginTop="@dimen/_24dp"
            android:background="@drawable/bg_et_login"
            android:drawableEnd="@drawable/ic_et_birthday"
            android:fontFamily="@font/manrope_semibold"
            android:hint="@string/birthday"
            android:focusableInTouchMode="false"
            android:includeFontPadding="false"
            android:minHeight="52dp"
            android:paddingHorizontal="@dimen/_24dp"
            android:textColor="@color/white"
            android:textColorHint="@color/white70"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/etName" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20dp"
            android:layout_marginTop="@dimen/_24dp"
            android:focusableInTouchMode="false"
            android:background="@drawable/bg_et_login"
            android:drawableEnd="@drawable/ic_et_arrow_down"
            android:fontFamily="@font/manrope_semibold"
            android:hint="@string/biological_sex"
            android:includeFontPadding="false"
            android:minHeight="52dp"
            android:paddingHorizontal="@dimen/_24dp"
            android:textColor="@color/white"
            android:textColorHint="@color/white70"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/etBirthday" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_24dp"
            android:layout_marginTop="@dimen/_50dp"
            android:layout_marginBottom="@dimen/_32dp"
            android:backgroundTint="@color/btn_continue"
            android:text="@string/next"
            android:textColor="@color/btn_text_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1" />


    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.core.widget.NestedScrollView>