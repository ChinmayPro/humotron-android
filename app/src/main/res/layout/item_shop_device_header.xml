<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="22dp"
    android:paddingTop="26dp"
    android:paddingBottom="20dp">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvMainHeading"
        style="@style/Text.24x.Manrope.ExtraBold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Discover &amp; shop\nHumotron devices."
        android:letterSpacing="-0.025" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvSubHeading"
        style="@style/Text.12_5x.Manrope.Medium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="First-party hardware that streams straight into Track. Your readings, captured the moment they happen."
        android:textColor="#CFDAD8"
        android:lineSpacingMultiplier="1.55" />

</LinearLayout>
