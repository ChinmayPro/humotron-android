<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@drawable/ic_bg_main_2"
    tools:context=".ui.device.cuff.SmartCuffBPReadingFragment">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mcvDeviceDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_14dp"
        app:cardBackgroundColor="@color/white10"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/_16dp"
            android:paddingVertical="@dimen/_14dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDeviceName"
                style="@style/Text.14x.Manrope.Bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_12dp"
                android:text="@string/humotron_smart_weight_scale"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivStatusDot"
                android:layout_width="@dimen/_7dp"
                android:layout_height="@dimen/_7dp"
                android:layout_marginTop="@dimen/_8dp"
                android:src="@drawable/dot_disconnected"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDeviceName" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDeviceStatus"
                style="@style/Text.10x.Manrope.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_6dp"
                android:text="@string/inactive"
                android:textColor="@color/disconnected"
                app:layout_constraintBottom_toBottomOf="@id/ivStatusDot"
                app:layout_constraintStart_toEndOf="@id/ivStatusDot"
                app:layout_constraintTop_toTopOf="@id/ivStatusDot" />

            <com.humotron.app.view.BatteryView
                android:id="@+id/batteryView"
                android:layout_width="@dimen/_20dp"
                android:layout_height="@dimen/_10dp"
                android:layout_marginEnd="@dimen/_5dp"
                app:layout_constraintBottom_toBottomOf="@+id/tvBatteryLevel"
                app:layout_constraintEnd_toStartOf="@+id/tvBatteryLevel"
                app:layout_constraintTop_toTopOf="@+id/tvBatteryLevel" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvBatteryLevel"
                style="@style/Text.8x.Manrope.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textAlignment="center"
                app:layout_constraintBottom_toBottomOf="@+id/tvDeviceStatus"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tvDeviceStatus" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvMeasureTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_14dp"
        android:fontFamily="@font/manrope_bold"
        android:lineSpacingExtra="0dp"
        android:text="@string/please_remain_calm_and_still"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mcvDeviceDetails"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tvMeasureSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_5dp"
        android:fontFamily="@font/manrope_medium"
        android:text="@string/your_blood_pressure_measurement_is_in_progress"
        android:textColor="@color/ink2"
        android:textSize="14.5sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvMeasureTitle"
        tools:visibility="visible" />

    <com.humotron.app.view.BpMeasurementView
        android:id="@+id/bpView"
        android:layout_width="60dp"
        android:layout_height="300dp"
        android:layout_marginStart="@dimen/_20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:barLabelGapBP="@dimen/_14dp"
        app:fillColorEnd="#5FBF6E"
        app:fillColorStart="#9BE84F"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvMeasureSubtitle"
        app:maxValue="220"
        app:minValue="10"
        app:showValueLabel="false"
        app:step="30"
        app:stepTextSize="9.5sp"
        app:textColor="#000000"
        app:textColorBP="@color/ink4"
        app:trackColor="#11FFFFFF" />

    <LinearLayout
        android:id="@+id/ll_bp_measure_error"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_28dp"
        android:layout_marginTop="@dimen/_18dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/bpView"
        app:layout_constraintTop_toTopOf="@+id/bpView"
        tools:visibility="gone">

        <TextView
            style="@style/Text.22x.Manrope.Bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="0dp"
            android:text="@string/oops_something_went_wrong"
            android:textColor="#F44545"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/bpView"
            app:layout_constraintTop_toTopOf="@+id/bpView" />

        <TextView
            style="@style/Text.14x.Manrope.Medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10dp"
            android:text="@string/don_t_worry_it_happens"
            android:textColor="@color/ink2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/bpView"
            app:layout_constraintTop_toBottomOf="@id/tvMeasureTitle" />

        <TextView
            style="@style/Text.14x.Manrope.Medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20dp"
            android:text="@string/please_ensure_your_arm_is_positioned"
            android:textColor="@color/ink2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/bpView"
            app:layout_constraintTop_toBottomOf="@id/tvMeasureTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetryMeasurement"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="39dp"
            android:paddingHorizontal="@dimen/_22dp"
            android:paddingVertical="@dimen/_10dp"
            android:text="@string/retry_measurement"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@android:color/transparent"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.Button.Circle"
            app:strokeColor="@color/ink2"
            app:strokeWidth="1dp" />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clBPCalc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_20dp"
        android:layout_marginEnd="@dimen/_20dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@+id/bpView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/bpView"
        app:layout_constraintTop_toTopOf="@id/bpView"
        tools:visibility="visible">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvMeasureSystolicValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_extra_bold"
            android:includeFontPadding="false"
            android:text="124"
            android:textColor="@color/black"
            android:textSize="42sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvMeasureSystolicUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_7dp"
            android:layout_marginBottom="@dimen/_10dp"
            android:text="mmHg"
            android:textColor="@color/ink3"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@id/tvMeasureSystolicValue"
            app:layout_constraintStart_toEndOf="@id/tvMeasureSystolicValue" />

        <LinearLayout
            android:id="@+id/llMeasureDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMeasureSystolicValue">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_semibold"
                    android:gravity="center_vertical"
                    android:text="Systolic Pressure"
                    android:textColor="@color/ink3"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_semibold"
                    android:gravity="center_vertical"
                    android:text="Diastolic Pressure"
                    android:textColor="@color/ink3"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_semibold"
                    android:gravity="center_vertical"
                    android:text="Blood Pressure"
                    android:textColor="@color/ink3"
                    android:textSize="13sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMeasureSystolicReading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_10dp"
                    android:fontFamily="@font/manrope_extra_bold"
                    android:text="@string/calculating"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvMeasureDiastolicReading"
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_10dp"
                    android:fontFamily="@font/manrope_extra_bold"
                    android:text="@string/calculating"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvMeasurePulseReading"
                    style="@style/Text.14x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_10dp"
                    android:fontFamily="@font/manrope_extra_bold"
                    android:text="@string/calculating"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginBottom="10dp"
        android:fontFamily="@font/manrope_bold"
        android:text="@string/stop"
        android:textAllCaps="false"
        android:textColor="@color/ink3"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/transparent"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
