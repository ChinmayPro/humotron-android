<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:paddingTop="13dp"
    android:paddingBottom="13dp">

    <!-- Circle checkmark -->
    <LinearLayout
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/circle_white"
        android:backgroundTint="#1F7BD88F"
        android:gravity="center"
        android:layout_marginEnd="12dp">

        <ImageView
            android:layout_width="17dp"
            android:layout_height="17dp"
            android:src="@drawable/ic_check_thin"
            app:tint="@color/booster_accent_good"
            android:contentDescription="Check" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvLogName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/textColorWhite"
            android:textSize="15sp"
            android:layout_marginBottom="2dp"
            android:text="Almond Spinach Omelette" />

        <TextView
            android:id="@+id/tvLogMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:textColor="@color/textColorMuted"
            android:textSize="13sp"
            android:text="Breakfast · Oct 12" />
    </LinearLayout>

    <!-- Metric text -->
    <TextView
        android:id="@+id/tvLogMetric"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-bold"
        android:textColor="@color/deep_dives_cool"
        android:textSize="11sp"
        android:text="Systolic BP" />
</LinearLayout>
