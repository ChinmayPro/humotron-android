<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:background="@drawable/ic_bg_main"
    tools:context=".ui.onboarding.personalize.WidthHeightFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTitle"
            style="@style/Text.OnBoard.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_100dp"
            android:text="@string/well_done"
            android:textColor="@color/colorBgBtn"
            android:textSize="27sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSubtitle"
            style="@style/Text.OnBoard.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_6dp"
            android:text="@string/you_re_set"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvDesc"
            style="@style/Text.OnBoard.Desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_26dp"
            android:gravity="center"
            android:paddingStart="@dimen/_24dp"
            android:paddingEnd="@dimen/_48dp"
            android:text="@string/complete_desc"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />


        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_48dp"
            android:layout_marginHorizontal="@dimen/_56dp"
            android:layout_marginTop="@dimen/_50dp"
            android:background="@drawable/bg_btn_round_corner"
            android:drawableEnd="@drawable/ic_arrow_right_begin"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvDesc">

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text.OnBoard.Title1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableEnd="@drawable/ic_arrow_right_begin"
                android:drawablePadding="@dimen/_12dp"
                android:text="@string/go_to_dashboard"
                android:textColor="@color/btn_text_color" />

        </androidx.appcompat.widget.LinearLayoutCompat>


    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.core.widget.NestedScrollView>