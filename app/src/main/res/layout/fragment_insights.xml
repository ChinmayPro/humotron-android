<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.profile.InsightsFragment">

    <include
        android:id="@+id/header"
        layout="@layout/layout_header_2"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="16dp">

            <!-- Intro Section -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_rounded_14"
                android:backgroundTint="#19C4F23E"
                android:gravity="center">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    android:src="@drawable/ic_spark"
                    app:tint="#C4F23E" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text.OnBoard.Title1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="Insights"
                android:textSize="21sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.5"
                android:text="Decide how deeply, how often, and on what Humotron analyses your data."
                android:textColor="#A0B3AF"
                android:textSize="13sp" />

            <!-- Insight style -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="Insight style"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="How detailed should your insights be?"
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_style_chip" android:id="@+id/chipStyleSimple" />
                <include layout="@layout/item_insight_style_chip" android:id="@+id/chipStyleBalanced" />
                <include layout="@layout/item_insight_style_chip" android:id="@+id/chipStyleDeep" />
            </com.google.android.flexbox.FlexboxLayout>

            <!-- Frequency -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="Frequency"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="How often should we analyse your data?"
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_chip" android:id="@+id/chipFreqDaily" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipFreq7" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipFreq14" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipFreq21" />
            </com.google.android.flexbox.FlexboxLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/manrope_regular"
                android:lineSpacingMultiplier="1.35"
                android:text="More frequent insights capture short-term changes. Less frequent insights focus on deeper trends."
                android:textColor="#859390"
                android:textSize="11.5sp"
                app:fontFamily="@font/manrope_regular" />

            <!-- Focus areas -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="Focus areas"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="What should we focus on?"
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_chip" android:id="@+id/chipFocusRecovery" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipFocusStress" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipFocusSleep" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipFocusActivity" />
            </com.google.android.flexbox.FlexboxLayout>

            <!-- Insight triggers -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="Insight triggers"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="How should we notify you?"
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTriggerApp" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTriggerEmails" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTriggerBoth" />
            </com.google.android.flexbox.FlexboxLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Gradient Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_bottom_fade"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Save Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSaveInsights"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="22dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_btn_lime_pill"
        android:text="Save"
        android:textAllCaps="false"
        android:textColor="#0d1618"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
