<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_decode_card"
    android:clickable="true"
    android:focusable="true"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvPair"
        style="@style/Text.10x.Manrope.Bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        tools:text="HRV VS TEMPERATURE"
        android:textColor="@color/deep_dives_eyebrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Badge for Ready or Collecting state (can dynamically change background/textColor) -->
    <TextView
        android:id="@+id/badgeScore"
        style="@style/Text.10x.Manrope.Bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_deep_dives_badge_ready"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        tools:text="47% · Moderate"
        android:textColor="@color/deep_dives_lime"
        android:textSize="9.5sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvWeatherTitle"
        style="@style/Text.16x.Manrope.Bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        tools:text="Cooler days boost your recovery"
        android:textColor="@color/white"
        android:textSize="15.5sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPair" />

    <TextView
        android:id="@+id/tvWeatherDesc"
        style="@style/Text.13x.Manrope.Regular"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        tools:text="Generated 09 Apr 2026"
        android:textColor="@color/deep_dives_ink3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvWeatherTitle" />

    <View
        android:id="@+id/vDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:background="@color/deep_dives_hair"
        app:layout_constraintTop_toBottomOf="@id/tvWeatherDesc" />

    <!-- Action container for Ready or Collecting states -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clActionReady"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/vDivider">

        <TextView
            android:id="@+id/tvActionView"
            style="@style/Text.13x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/action_view_report"
            android:textColor="@color/deep_dives_lime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvActionNext"
            style="@style/Text.13x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/action_generate_next"
            android:textColor="@color/deep_dives_lime"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/llCollectProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvCollectCount"
                style="@style/Text.10x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Next · 142 / 180 days"
                android:textColor="@color/deep_dives_ink3" />

            <FrameLayout
                android:layout_width="24dp"
                android:layout_height="4dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_progress_track">
                <View
                    android:id="@+id/vCollectProgress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@color/deep_dives_watch" />
            </FrameLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Generate button for Generate state -->
    <TextView
        android:id="@+id/btnGenerate"
        style="@style/Text.15x.Manrope.SemiBold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_cta_lime"
        android:fontFamily="@font/manrope_bold"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:text="@string/action_generate_report"
        android:textColor="@color/deep_dives_bg"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/vDivider" />

</androidx.constraintlayout.widget.ConstraintLayout>
