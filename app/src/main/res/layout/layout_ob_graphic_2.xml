<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_ob_card"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constrainedWidth="true"
        app:layout_constraintWidth_max="260dp">

        <TextView
            android:id="@+id/tvEyebrow"
            style="@style/Text.10x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:text="@string/ob_graphic_2_eyebrow"
            android:textAllCaps="true"
            android:textColor="@color/insights_light_green" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.15x.Manrope.SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/manrope_bold"
            android:lineSpacingMultiplier="1.3"
            android:text="@string/insights_optimize_lagging_title" />

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/llPills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:flexWrap="wrap"
            app:alignContent="flex_start"
            app:alignItems="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ob_pill_heart"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="7dp"
                android:layout_marginBottom="7dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    app:tint="#F0795E"
                    android:src="@drawable/ic_onboard_heart" />

                <TextView
                    style="@style/Text.11x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="@string/ob_graphic_2_hrv_down" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ob_pill_moon"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:layout_marginBottom="7dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    app:tint="#5FB7C4"
                    android:src="@drawable/ic_onboard_moon" />

                <TextView
                    style="@style/Text.11x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="@string/ob_graphic_2_deep_down" />
            </LinearLayout>
        </com.google.android.flexbox.FlexboxLayout>

        <TextView
            style="@style/Text.12x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:background="@drawable/bg_ob_pill_try"
            android:paddingHorizontal="14dp"
            android:paddingVertical="9dp"
            android:text="@string/ob_graphic_2_try_one_thing"
            android:textColor="@color/insights_btn_text_dark" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
