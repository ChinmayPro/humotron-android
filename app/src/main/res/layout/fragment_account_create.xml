<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.onboarding.fragments.AccountCreateFragment">

    <include layout="@layout/bg_main" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/_50dp">


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_account_create"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/Text.OnBoard.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_24dp"
                android:gravity="center"
                android:text="@string/your_account_created_successfully"
                android:textSize="27sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivIcon" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDesc"
                style="@style/Text.OnBoard.Sub.Medium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_40dp"
                android:layout_marginTop="@dimen/_18dp"
                android:gravity="center"
                android:text="@string/account_create_desc"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />


            <View
                android:id="@+id/divider"
                android:layout_width="2dp"
                android:layout_height="0dp"
                android:layout_marginVertical="@dimen/_15dp"
                android:background="@color/white"
                app:layout_constraintBottom_toBottomOf="@id/tv4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv1" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv1"
                style="@style/Text.OnBoard.Sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_18dp"
                android:layout_marginEnd="@dimen/_20dp"
                android:gravity="center"
                android:text="@string/personal_info"
                android:textSize="16sp"
                app:layout_constraintEnd_toStartOf="@id/divider"
                app:layout_constraintTop_toBottomOf="@id/tvDesc" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv2"
                style="@style/Text.OnBoard.Sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_20dp"
                android:layout_marginTop="@dimen/_40dp"
                android:gravity="center"
                android:text="@string/body_stats"
                android:textSize="16sp"
                app:layout_constraintStart_toEndOf="@id/divider"
                app:layout_constraintTop_toBottomOf="@id/tv1" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv3"
                style="@style/Text.OnBoard.Sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_40dp"
                android:layout_marginEnd="@dimen/_20dp"
                android:gravity="center"
                android:text="@string/use_cases"
                android:textSize="16sp"
                app:layout_constraintEnd_toStartOf="@id/divider"
                app:layout_constraintTop_toBottomOf="@id/tv2" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv4"
                style="@style/Text.OnBoard.Sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_20dp"
                android:layout_marginTop="@dimen/_40dp"
                android:gravity="center"
                android:text="@string/dashboard"
                android:textSize="16sp"
                app:layout_constraintStart_toEndOf="@id/divider"
                app:layout_constraintTop_toBottomOf="@id/tv3" />

            <View
                android:layout_width="@dimen/_10dp"
                android:layout_height="@dimen/_10dp"
                android:background="@drawable/bg_round_white"
                app:layout_constraintBottom_toBottomOf="@id/tv1"
                app:layout_constraintEnd_toEndOf="@id/divider"
                app:layout_constraintStart_toStartOf="@id/divider"
                app:layout_constraintTop_toTopOf="@id/tv1" />

            <View
                android:layout_width="@dimen/_10dp"
                android:layout_height="@dimen/_10dp"
                android:background="@drawable/bg_round_white"
                app:layout_constraintBottom_toBottomOf="@id/tv2"
                app:layout_constraintEnd_toEndOf="@id/divider"
                app:layout_constraintStart_toStartOf="@id/divider"
                app:layout_constraintTop_toTopOf="@id/tv2" />


            <View
                android:layout_width="@dimen/_10dp"
                android:layout_height="@dimen/_10dp"
                android:background="@drawable/bg_round_white"
                app:layout_constraintBottom_toBottomOf="@id/tv3"
                app:layout_constraintEnd_toEndOf="@id/divider"
                app:layout_constraintStart_toStartOf="@id/divider"
                app:layout_constraintTop_toTopOf="@id/tv3" />


            <View
                android:layout_width="@dimen/_10dp"
                android:layout_height="@dimen/_10dp"
                android:background="@drawable/bg_round_white"
                app:layout_constraintBottom_toBottomOf="@id/tv4"
                app:layout_constraintEnd_toEndOf="@id/divider"
                app:layout_constraintStart_toStartOf="@id/divider"
                app:layout_constraintTop_toTopOf="@id/tv4" />


            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_48dp"
                android:layout_marginHorizontal="@dimen/_24dp"
                android:layout_marginTop="@dimen/_50dp"
                android:background="@drawable/bg_btn_round_corner"
                android:drawableEnd="@drawable/ic_arrow_right_begin"
                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.OnBoard.Title1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@drawable/ic_arrow_right_begin"
                    android:drawablePadding="@dimen/_12dp"
                    android:text="@string/lets_begin"
                    android:textColor="@color/btn_text_color" />

            </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>