<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include
        android:id="@+id/header"
        layout="@layout/layout_header_left"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_56dp"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="14dp">

            <!-- Source Card Group (.srcgroup) -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:background="@drawable/bg_source_group"
                android:orientation="horizontal"
                android:padding="16dp">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/llDeviceIcon"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:gravity="center"
                    android:background="@drawable/bg_rounded_12"
                    android:backgroundTint="#265FB7C4">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivDeviceIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_weather"
                        app:tint="#5FB7C4" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- .snm2: font-size:14.5px; font-weight:700 -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Environmental Context"
                        android:textColor="#FFFFFF"
                        android:textSize="14.5sp"
                        app:fontFamily="@font/manrope_bold" />

                    <!-- .sx3: color:ink3=#859390; font-size:11.5px -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvDeviceDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_regular"
                        android:text="Weather &amp; environmental correlations"
                        android:textColor="#859390"
                        android:textSize="11.5sp"
                        app:fontFamily="@font/manrope_regular" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Status Badge Pill (.anonpill) -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="13dp"
                android:background="@drawable/bg_anon_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="13dp"
                android:paddingVertical="8dp">

                <View
                    android:id="@+id/vStatusDot"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:background="@drawable/bg_status_dot_with_shadow" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:fontFamily="@font/manrope_bold"
                    android:textStyle="bold"
                    android:text="Active"
                    android:textColor="#cfdad8"
                    android:textSize="12sp"
                    app:fontFamily="@font/manrope_bold" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Used For Section (.cfgsec) -->
            <!-- .cq: color:#fff; font-size:15px; font-weight:800 -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:textStyle="bold"
                android:text="Used for"
                android:textColor="#FFFFFF"
                android:textSize="16.5sp"
                app:fontFamily="@font/manrope_extra_bold" />

            <!-- .ch: color:ink3=#859390; font-size:12.5px -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/manrope_regular"
                android:text="Choose where this source is allowed to help."
                android:textColor="#859390"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <!-- Used For Switches Card (.cfgcard) -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_cfg_card"
                android:orientation="vertical">

                <!-- Row 1: Insights & correlations (.mgrow .mn: font-size:14px) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="15dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Insights &amp; correlations"
                        android:textColor="#FFFFFF"
                        android:textSize="15.5sp"
                        app:fontFamily="@font/manrope_bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switchInsights"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchInsights"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#12FFFFFF" />

                <!-- Row 2: Smart suggestions -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="15dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Smart suggestions"
                        android:textColor="#FFFFFF"
                        android:textSize="15.5sp"
                        app:fontFamily="@font/manrope_bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switchSuggestions"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchSuggestions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#12FFFFFF" />

                <!-- Row 3: Chat context -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="15dp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Chat context"
                        android:textColor="#FFFFFF"
                        android:textSize="15.5sp"
                        app:fontFamily="@font/manrope_bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/switchChat"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchChat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Encrypted & private (.promise) -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_promise_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <!-- .pi: 34x34, border-radius:10px, bg:rgba(196,242,62,.1), color:lime -->
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_promise_icon_box"
                    android:gravity="center">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_lock_outline"
                        app:tint="#C4F23E" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <!-- .ph: color:#fff; font-size:13px; font-weight:700 -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Encrypted &amp; private"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        app:fontFamily="@font/manrope_bold" />

                    <!-- .pp: color:ink3=#859390; font-size:11.5px -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_regular"
                        android:lineSpacingMultiplier="1.45"
                        android:text="Used only to personalise your analysis. Never shared."
                        android:textColor="#859390"
                        android:textSize="11.5sp"
                        app:fontFamily="@font/manrope_regular" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Your Controls Section (.cfgsec) -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:textStyle="bold"
                android:text="Your controls"
                android:textColor="#FFFFFF"
                android:textSize="16.5sp"
                app:fontFamily="@font/manrope_extra_bold" />

            <!-- Pause Source Row (.ctrlrow) -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llPauseSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_ctrl_row"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp">

                <!-- .ci: 38x38, border-radius:11px, bg:rgba(255,255,255,.05) -->
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_ctrl_icon_box"
                    android:gravity="center">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_alarm_24px"
                        app:tint="#E7A93C" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- .cn: color:#fff; font-size:14.5px; font-weight:700 -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Pause this source"
                        android:textColor="#FFFFFF"
                        android:textSize="15.5sp"
                        app:fontFamily="@font/manrope_bold" />

                    <!-- .cx: color:ink4=#6F7E7D; font-size:11.5px -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvPauseDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_regular"
                        android:text="Temporarily stop using Environmental Context"
                        android:textColor="#6F7E7D"
                        android:textSize="11.5sp"
                        app:fontFamily="@font/manrope_regular" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <!-- Delete All Data Row (.ctrlrow) -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llDeleteSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_ctrl_row"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp">

                <!-- .ci with color:series -->
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_ctrl_icon_box"
                    android:gravity="center">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_delete"
                        app:tint="#F0795E" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- .cn with color:series -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textStyle="bold"
                        android:text="Delete all data"
                        android:textColor="#F0795E"
                        android:textSize="15.5sp"
                        app:fontFamily="@font/manrope_bold" />

                    <!-- .cx: color:ink4=#6F7E7D -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvDeleteDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_regular"
                        android:text="Permanently remove everything from this source"
                        android:textColor="#6F7E7D"
                        android:textSize="11.5sp"
                        app:fontFamily="@font/manrope_regular" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
