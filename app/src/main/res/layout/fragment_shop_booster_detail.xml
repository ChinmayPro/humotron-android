<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Common Toolbar included (.backhead style) -->
    <include
        android:id="@+id/clHeaderCard"
        layout="@layout/layout_header_2"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/clFooter"
        app:layout_constraintTop_toBottomOf="@id/clHeaderCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ══════ HERO CARD (.pbhero) ══════ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clHeroCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_booster"
                android:padding="18dp">

                <!-- Tag row: icon + BOOSTER -->
                <LinearLayout
                    android:id="@+id/llBoosterTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivBoosterTagIcon"
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_spark"
                        app:tint="@color/lime_green" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvBoosterTagText"
                        style="@style/Text.11x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:layout_gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:text="@string/booster_tag_label"
                        android:textColor="@color/lime_green"
                        android:letterSpacing="0.04" />
                </LinearLayout>

                <!-- Name row + Price area -->
                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvBoosterName"
                    style="@style/Text.24x.Manrope.Bold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="14dp"
                    android:textColor="@color/white"
                    android:letterSpacing="-0.025"
                    app:layout_constraintEnd_toStartOf="@id/layoutPriceArea"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/llBoosterTag"
                    tools:text="AI Chat" />

                <!-- Tagline -->
                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvBoosterTagline"
                    style="@style/Text.13x.Manrope.Regular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:textColor="@color/textColorMuted"
                    android:lineSpacingMultiplier="1.5"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvBoosterName"
                    tools:text="Ask your own data anything." />

                <!-- Price area -->
                <LinearLayout
                    android:id="@+id/layoutPriceArea"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/tvBoosterName"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvBoosterName">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvBoosterPrice"
                        style="@style/Text.22x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/lime_green"
                        android:letterSpacing="-0.02"
                        tools:text="£6.90" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvBoosterPeriod"
                        style="@style/Text.11x.Manrope.SemiBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="monthly"
                        android:textColor="@color/colorTextGrey" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ══════ LONG DESCRIPTION (.body) ══════ -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDescription"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="15dp"
                android:textColor="@color/colorTextGrey"
                tools:text="You have weeks of health data — but what's it actually saying? Tron AI helps you ask, and understand, what's behind the numbers." />

            <!-- ══════ WHAT YOU'LL UNLOCK BOX (.unlockbox) ══════ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clUnlockBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="14dp"
                android:padding="16dp">

                <!-- Title: spark + WHAT YOU'LL UNLOCK -->
                <LinearLayout
                    android:id="@+id/llUnlockTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivUnlockTitleIcon"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_spark"
                        app:tint="@color/lime_green" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvUnlockTitleText"
                        style="@style/Text.11x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:text="@string/what_you_will_unlock"
                        android:textColor="@color/lime_green"
                        android:letterSpacing="0.04" />
                </LinearLayout>

                <!-- Benefits list (dynamically populated) -->
                <LinearLayout
                    android:id="@+id/llUnlockBenefitsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/llUnlockTitle" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ══════ PREVIEW MOCK CARD (.previewmock) ══════ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clPreviewMock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_preview_mock"
                android:padding="20dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvPreviewTitle"
                    style="@style/Text.16x.Manrope.Bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:letterSpacing="-0.01"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/preview_mock_title" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvPreviewDesc"
                    style="@style/Text.12x.Manrope.Medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5"
                    android:textColor="@color/colorTextGrey"
                    app:layout_constraintTop_toBottomOf="@id/tvPreviewTitle"
                    android:text="@string/preview_mock_desc" />

                <!-- Chat Mock (.chatmock) — max-width 250dp centered -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tvPreviewDesc">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/clChatMock"
                        android:layout_width="250dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/bg_chat_mock"
                        android:padding="14dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvChatTime"
                            style="@style/Text.11x.Manrope.SemiBold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preview_mock_chat_time"
                            android:textColor="@color/colorTextGrey"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvChatQuestion"
                            style="@style/Text.12x.Manrope.Bold"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textColor="@color/white"
                            app:layout_constraintTop_toBottomOf="@id/tvChatTime"
                            android:text="@string/preview_mock_chat_question" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvChatResponse"
                            style="@style/Text.12x.Manrope.Medium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:lineSpacingMultiplier="1.5"
                            android:padding="11dp"
                            android:textColor="@color/textColorMuted"
                            app:layout_constraintTop_toBottomOf="@id/tvChatQuestion"
                            android:text="@string/preview_mock_chat_response" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Image preview screen fallback (hidden by default) -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivPreviewScreen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="16dp"
                android:adjustViewBounds="true"
                android:visibility="gone" />

            <!-- ══════ TRUST ROW (.trustrow) — VERTICAL column ══════ -->
            <LinearLayout
                android:id="@+id/clTrustRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:paddingHorizontal="22dp"
                android:orientation="vertical">

                <!-- Bullet 1 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_big_green_check"
                        app:tint="@color/booster_accent_good" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:text="@string/trust_bullet_cancel"
                        android:textColor="@color/textColorMuted"
                        android:textSize="12.5sp"
                        android:fontFamily="@font/manrope_semibold"
                        app:fontFamily="@font/manrope_semibold" />
                </LinearLayout>

                <!-- Bullet 2 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_big_green_check"
                        app:tint="@color/booster_accent_good" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:text="@string/trust_bullet_privacy"
                        android:textColor="@color/textColorMuted"
                        android:textSize="12.5sp"
                        android:fontFamily="@font/manrope_semibold"
                        app:fontFamily="@font/manrope_semibold" />
                </LinearLayout>

                <!-- Bullet 3 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_big_green_check"
                        app:tint="@color/booster_accent_good" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:text="@string/trust_bullet_users"
                        android:textColor="@color/textColorMuted"
                        android:textSize="12.5sp"
                        android:fontFamily="@font/manrope_semibold"
                        app:fontFamily="@font/manrope_semibold" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ══════ STICKY FOOTER (.sheetfoot) ══════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_footer_gradient"
        android:paddingHorizontal="22dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Owned bar (hidden by default) -->
        <LinearLayout
            android:id="@+id/layoutOwnedBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_booster_unlocked"
            android:paddingVertical="15dp"
            android:paddingHorizontal="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_big_green_check"
                app:tint="@color/booster_accent_good" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvOwnedBarText"
                style="@style/Text.14x.Manrope.SemiBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="11dp"
                android:textColor="@color/white"
                tools:text="AI Chat is active" />
        </LinearLayout>

        <!-- CTA Buy Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBuyNow"
            style="@style/Text.16x.Manrope.Bold"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_round_corner"
            android:backgroundTint="@color/lime_green"
            android:textAllCaps="false"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/layoutOwnedBar"
            tools:text="Add AI Chat — £6.90/mo" />

        <!-- Ghost CTA: Explore Pro Plan -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnExploreProPlan"
            style="@style/Text.14x.Manrope.Bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:background="@drawable/bg_btn_ghost"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:textColor="@color/booster_text_ghost"
            app:layout_constraintTop_toBottomOf="@id/btnBuyNow"
            tools:text="Or get it in the Pro plan" />

    </androidx.constraintlayout.widget.ConstraintLayout>



    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/white"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
