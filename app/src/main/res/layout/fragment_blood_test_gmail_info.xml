<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.bloodTest.BloodTestGmailInfoFragment">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        app:navigationIcon="@drawable/ic_back_arrow"
        app:navigationIconTint="@color/white"
        app:title="@string/upload_blood_test_report"
        app:titleTextColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:layout_marginTop="5dp"
        android:background="@color/dividerColor"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPrivacyFirst"
                style="@style/Text.24x.Manrope.Bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/privacy_first"
                android:textColor="@color/lime_green"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPrivacyDesc"
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/gmail_privacy_desc"
                android:textColor="@color/colorBgBtn1"
                android:layout_marginBottom="15dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvHowItWorks"
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/how_it_works_colon"
                android:textColor="@color/white70"
                android:layout_marginBottom="32dp" />

            <!-- Step 1 -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvStep1Title"
                style="@style/Text.20x.Manrope.SemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/step_1_connect_gmail"
                android:layout_marginBottom="8dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvStep1Desc"
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/step_1_connect_gmail_desc"
                android:textColor="@color/white70"
                android:layout_marginBottom="24dp" />

            <!-- Step 2 -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvStep2Title"
                style="@style/Text.20x.Manrope.SemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/step_2_specify_keywords"
                android:layout_marginBottom="8dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvStep2Desc"
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/step_2_specify_keywords_desc"
                android:textColor="@color/white70"
                android:layout_marginBottom="24dp" />

            <!-- Step 3 -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvStep3Title"
                style="@style/Text.20x.Manrope.SemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/step_3_select_reports"
                android:layout_marginBottom="8dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvStep3Desc"
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/step_3_select_reports_desc"
                android:textColor="@color/white70"
                android:layout_marginBottom="24dp" />

            <!-- Step 4 -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvStep4Title"
                style="@style/Text.20x.Manrope.SemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/step_4_confirm_import"
                android:layout_marginBottom="8dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvStep4Desc"
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/step_4_confirm_import_desc"
                android:textColor="@color/white70"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/assessmentBnt"
            android:fontFamily="@font/manrope_bold"
            android:text="@string/_continue"
            android:textAllCaps="false"
            android:textColor="@color/d900"
            android:textSize="15sp"
            app:cornerRadius="26dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
