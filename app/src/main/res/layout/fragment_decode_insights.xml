<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- 1. INSIGHTS HOME VIEW -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layoutHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    style="@style/Text.10x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_decode"
                    android:textColor="@color/insights_header_grey"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12" />

                <TextView
                    style="@style/Text.24x.Manrope.Bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/insights_home_title"
                    android:textColor="@color/white" />

                <TextView
                    style="@style/Text.14x.Manrope.Regular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/insights_subtitle"
                    android:textColor="@color/insights_light_grey"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Section Divider Label -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="15dp">
                <TextView
                    style="@style/Text.11x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/insights_your_metrics"
                    android:textColor="@color/insights_section_header_grey"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"/>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/white10"
                    android:layout_alignParentEnd="true"
                    android:layout_marginStart="110dp"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- Loading indicator for metrics (Shimmer) -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerMetricsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:shimmer_auto_start="true"
                app:shimmer_base_alpha="0.8"
                app:shimmer_base_color="#ffffff"
                app:shimmer_duration="1000">

                <include layout="@layout/layout_insights_shimmer" />

            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- Metrics list cards -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMetricsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:layout_marginTop="12dp"
                tools:listitem="@layout/item_decode_metric_card" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
