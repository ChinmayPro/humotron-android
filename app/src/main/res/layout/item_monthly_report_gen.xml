<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_decode_card"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="top"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMonth"
                style="@style/Text.16x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvRange"
                style="@style/Text.12x.Manrope.Regular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/deep_dives_ink3" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvBadge"
            style="@style/Text.10x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_deep_dives_badge_ready"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/status_data_ready"
            android:textAllCaps="true"
            android:textColor="@color/deep_dives_lime" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvNote"
        style="@style/Text.13x.Manrope.Regular"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/textColorDesc" />

    <!-- Assume bg_btn_lime is available for Generate report button -->
    <TextView
        android:id="@+id/btnGenerate"
        style="@style/Text.14x.Manrope.Bold"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_cta_lime"
        android:gravity="center"
        android:text="@string/action_generate_report"
        android:textColor="@color/black" />
</LinearLayout>
