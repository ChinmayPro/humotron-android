<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@color/black"
    tools:context=".ui.bioHack.PreferenceDoneFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_56dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatTextView
            style="@style/Text.16x.Manrope.SemiBold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivNuggets"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivNuggets"
            android:layout_width="@dimen/_20dp"
            android:layout_height="@dimen/_20dp"
            android:layout_marginEnd="@dimen/_20dp"
            android:src="@drawable/ic_nuggets_disable"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivBooks"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivBooks"
            android:layout_width="@dimen/_20dp"
            android:layout_height="@dimen/_20dp"
            android:layout_marginEnd="@dimen/_20dp"
            android:src="@drawable/ic_books_disable"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivProgress"
            app:layout_constraintTop_toTopOf="parent" />


        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivProgress"
            android:layout_width="@dimen/_20dp"
            android:layout_height="@dimen/_20dp"
            android:layout_marginEnd="@dimen/_20dp"
            android:src="@drawable/ic_biohack_progress_disable"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivSuccess"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_success_bio_hack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/textview1"
                style="@style/Text.24x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_20dp"
                android:text="@string/all_set_you_re_in"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivSuccess" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/textview2"
                style="@style/Text.16x.Manrope.Bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_24dp"
                android:gravity="center"
                android:text="@string/you_re_in_let_s_build_your_biohacking_mastery"
                android:textColor="@color/d9"
                app:layout_constraintEnd_toEndOf="@id/textview1"
                app:layout_constraintStart_toStartOf="@id/textview1"
                app:layout_constraintTop_toBottomOf="@id/textview1" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llNuggets"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_48dp"
                android:layout_marginTop="@dimen/_48dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textview2">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_20dp"
                    android:layout_height="@dimen/_20dp"
                    android:src="@drawable/ic_nuggets_disable"
                    app:tint="@color/textColorPink" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.16x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_16dp"
                    android:drawableEnd="@drawable/ic_arrow_right_begin"
                    android:drawablePadding="@dimen/_5dp"
                    android:drawableTint="@color/textColorPink"
                    android:includeFontPadding="false"
                    android:text="@string/explore_bite_sized_nuggets"
                    android:textColor="@color/textColorPink" />


            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llBooks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_48dp"
                android:layout_marginTop="@dimen/_30dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llNuggets">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_20dp"
                    android:layout_height="@dimen/_20dp"
                    android:src="@drawable/ic_books_disable"
                    app:tint="@color/textColorPink" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.16x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_16dp"
                    android:drawableEnd="@drawable/ic_arrow_right_begin"
                    android:drawablePadding="@dimen/_5dp"
                    android:drawableTint="@color/textColorPink"
                    android:includeFontPadding="false"
                    android:text="@string/deep_dive_with_books"
                    android:textColor="@color/textColorPink" />


            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llTrack"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_48dp"
                android:layout_marginTop="@dimen/_30dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llBooks">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_20dp"
                    android:layout_height="@dimen/_20dp"
                    android:src="@drawable/ic_biohack_progress_disable"
                    app:tint="@color/textColorPink" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.16x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_16dp"
                    android:drawableEnd="@drawable/ic_arrow_right_begin"
                    android:drawablePadding="@dimen/_5dp"
                    android:drawableTint="@color/textColorPink"
                    android:includeFontPadding="false"
                    android:text="@string/track_your_mastery"
                    android:textColor="@color/textColorPink" />


            </androidx.appcompat.widget.LinearLayoutCompat>


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>