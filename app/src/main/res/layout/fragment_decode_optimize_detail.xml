<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top Sticky Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnBack"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_back_arrow"
            android:padding="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            style="@style/Text.16x.Manrope.Bold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Magnesium Glycinate 400mg" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Loader -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="#C4F23E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clTopBar" />

    <!-- No Data Found -->
    <TextView
        android:id="@+id/tvNoData"
        style="@style/Text.16x.Manrope.SemiBold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_data_found"
        android:textColor="@color/white50"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clTopBar" />

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="10dp">

            <!-- Eyebrow -->
            <TextView
                android:id="@+id/tvEyebrow"
                style="@style/Text.11x.Manrope.SemiBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8A9594"
                android:textAllCaps="true"
                android:letterSpacing="0.06"
                tools:text="SUPPLEMENT" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                style="@style/Text.24x.Manrope.ExtraBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/white"
                tools:text="Magnesium Glycinate 400mg" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#9DACA9"
                android:lineSpacingMultiplier="1.25"
                tools:text="Calms the nervous system and eases your overnight heart rate." />

            <!-- Price -->
            <TextView
                android:id="@+id/tvPrice"
                style="@style/Text.20x.Manrope.Bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/white"
                tools:text="£24" />

            <!-- WHY YOU'RE SEEING THIS Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWhySeeingThis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:clipToOutline="true"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:id="@+id/flCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Left indicator bar -->
                    <View
                        android:id="@+id/vWhyLeftBorder"
                        android:layout_width="4.5dp"
                        android:layout_height="match_parent"
                        android:background="#C4F23E" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4.5dp"
                        android:orientation="vertical"
                        android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            style="@style/Text.10x.Manrope.Bold"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Why you're seeing this"
                            android:textColor="#C4F23E"
                            android:textAllCaps="true"
                            android:fontFamily="monospace"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.16" />

                        <TextView
                            android:id="@+id/tvMatchPercentage"
                            style="@style/Text.11x.Manrope.SemiBold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:fontFamily="monospace"
                            tools:text="91% match" />

                    </LinearLayout>

                    <!-- Metric row -->
                    <LinearLayout
                        android:id="@+id/llWhyMetricRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Pill Container -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_why_metric_pill"
                            android:paddingHorizontal="11dp"
                            android:paddingVertical="6dp">

                            <!-- Status Dot -->
                            <View
                                android:id="@+id/vWhyStatusDot"
                                android:layout_width="7dp"
                                android:layout_height="7dp"
                                android:background="@drawable/bg_round_green" />

                            <!-- Metric Name -->
                            <TextView
                                android:id="@+id/tvWhyMetricName"
                                style="@style/Text.12x.Manrope.SemiBold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:textColor="#9DACA9"
                                tools:text="HRV" />

                            <!-- Metric Delta -->
                            <TextView
                                android:id="@+id/tvWhyMetricDelta"
                                style="@style/Text.12x.Manrope.SemiBold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:textColor="@color/white"
                                tools:text="↓ 28%" />
                        </LinearLayout>

                        <TextView
                            style="@style/Text.12x.Manrope.Regular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="→"
                            android:textColor="#6F7E7D" />

                        <TextView
                            android:id="@+id/tvWhyRecoveryTarget"
                            style="@style/Text.12x.Manrope.SemiBold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textColor="#9DACA9"
                            tools:text="your recovery gap" />

                    </LinearLayout>

                    <!-- Expandable Rationale Hint/Trigger -->
                    <LinearLayout
                        android:id="@+id/clWhyExpandHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivWhyArrow"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_chevron_right_24px"
                            app:tint="@color/white50" />

                        <TextView
                            style="@style/Text.11x.Manrope.SemiBold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Why this, why you, why now"
                            android:textColor="@color/white50" />

                    </LinearLayout>

                    <!-- Rationale Section (Collapsible) -->
                    <LinearLayout
                        android:id="@+id/llWhyDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#12FFFFFF" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="7dp">

                            <TextView
                                android:id="@+id/tvDetailWhyThisLabel"
                                style="@style/Text.10x.Manrope.Bold"
                                android:layout_width="68dp"
                                android:layout_height="wrap_content"
                                android:textColor="#C4F23E"
                                android:textAllCaps="true"
                                android:text="Why this"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvDetailWhyThisContent"
                                style="@style/Text.12x.Manrope.Regular"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:textColor="#CFD8D7"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@id/tvDetailWhyThisLabel"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:text="Glycinate is the best-tolerated..." />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#12FFFFFF" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="7dp">

                            <TextView
                                android:id="@+id/tvDetailWhyYouLabel"
                                style="@style/Text.10x.Manrope.Bold"
                                android:layout_width="68dp"
                                android:layout_height="wrap_content"
                                android:textColor="#C4F23E"
                                android:textAllCaps="true"
                                android:text="Why you"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvDetailWhyYouContent"
                                style="@style/Text.12x.Manrope.Regular"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:textColor="#CFD8D7"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@id/tvDetailWhyYouLabel"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:text="Your low HRV..." />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#12FFFFFF" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="7dp">

                            <TextView
                                android:id="@+id/tvDetailWhyNowLabel"
                                style="@style/Text.10x.Manrope.Bold"
                                android:layout_width="68dp"
                                android:layout_height="wrap_content"
                                android:textColor="#C4F23E"
                                android:textAllCaps="true"
                                android:text="Why now"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvDetailWhyNowContent"
                                style="@style/Text.12x.Manrope.Regular"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:textColor="#CFD8D7"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@id/tvDetailWhyNowLabel"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:text="Three nights..." />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

            <!-- Badges Section -->
            <LinearLayout
                android:id="@+id/llBadges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvBadgeEvidence"
                    style="@style/Text.10x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_evidence"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:textColor="#C4F23E"
                    android:text="EVIDENCE-BASED"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvBadgeTested"
                    style="@style/Text.10x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_tested"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:textColor="#3AA8C1"
                    android:text="THIRD-PARTY TESTED"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvBadgeSafety"
                    style="@style/Text.10x.Manrope.Bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_safety"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:textColor="#8A9594"
                    android:text="STANDARD SAFETY" />

            </LinearLayout>

            <!-- Card 1: WHAT IT DOES -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWhatItDoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_semi_transparent"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="What it does"
                        android:textColor="#8A9594"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.16" />

                    <TextView
                        android:id="@+id/tvWhatItDoesContent"
                        style="@style/Text.13x.Manrope.Regular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="#CFD8D7"
                        android:lineSpacingExtra="5dp"
                        tools:text="Magnesium is a cofactor..." />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: HOW TO TAKE IT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHowToTakeIt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_semi_transparent"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How to take it"
                        android:textColor="#8A9594"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.16" />

                    <LinearLayout
                        android:id="@+id/llUsageTable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">
                        <!-- Populated programmatically as key-value rows -->
                    </LinearLayout>

                    <!-- Custom Form note -->
                    <LinearLayout
                        android:id="@+id/llFormNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_note_lime"
                        android:padding="12dp"
                        android:layout_marginTop="14dp"
                        android:gravity="top">

                        <!-- Diamond or info icon -->
                        <TextView
                            style="@style/Text.12x.Manrope.Bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦"
                            android:textColor="#C4F23E" />

                        <TextView
                            android:id="@+id/tvFormNoteText"
                            style="@style/Text.12x.Manrope.Regular"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textColor="#CFD8D7"
                            android:lineSpacingExtra="3dp"
                            tools:text="Why this form · glycinate avoids laxative effect..." />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 3: KEY INGREDIENTS / WHAT'S IN IT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_semi_transparent"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvIngredientsTitle"
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="What's in it"
                        android:textColor="#8A9594"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.16" />

                    <LinearLayout
                        android:id="@+id/llIngredientsList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">
                        <!-- Populated programmatically as ingredient rows -->
                    </LinearLayout>

                    <com.google.android.flexbox.FlexboxLayout
                        android:id="@+id/flexAllergenChips"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:flexDirection="row"
                        app:flexWrap="wrap"
                        app:justifyContent="flex_start">
                        <!-- Populated programmatically with allergen chips -->
                    </com.google.android.flexbox.FlexboxLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 4: THE EVIDENCE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEvidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_semi_transparent"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Evidence"
                        android:textColor="#8A9594"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.16" />

                    <TextView
                        android:id="@+id/tvEvidenceContent"
                        style="@style/Text.13x.Manrope.Regular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="#CFD8D7"
                        android:lineSpacingExtra="5dp"
                        tools:text="Strong evidence for muscle recovery..." />

                    <TextView
                        android:id="@+id/tvEvidenceBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_evidence_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textColor="#7FD6DC"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:textAllCaps="true"
                        android:visibility="gone"
                        tools:visibility="visible"
                        tools:text="Deficiency-Sensitive" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 5: SAFETY / WHO IT SUITS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSafety"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_semi_transparent"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Who it suits · Safety"
                        android:textColor="#8A9594"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.16" />

                    <LinearLayout
                        android:id="@+id/llSafetyTable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">
                        <!-- Populated programmatically as key-value rows -->
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 6: STACKS WELL WITH -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStacks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_semi_transparent"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stacks well with"
                        android:textColor="#8A9594"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.16" />

                    <LinearLayout
                        android:id="@+id/llStacksTable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">
                        <!-- Populated programmatically as key-value rows -->
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 7: HOW WE'LL TRACK THIS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTrack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_track_gradient"
                    android:padding="14dp">

                    <TextView
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How we'll track this"
                        android:textColor="#7FD6DC"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.16" />

                    <TextView
                        android:id="@+id/tvTrackContent"
                        style="@style/Text.13x.Manrope.Regular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#9DACA9"
                        android:textSize="12.5sp"
                        android:lineSpacingExtra="4dp"
                        tools:text="HRV, Resting HR" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 8: QUESTIONS / FAQs -->
            <!-- FAQ Header outside the card -->
            <TextView
                android:id="@+id/tvFaqsHeaderOutside"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="16dp"
                android:text="Questions"
                android:textColor="#8A9594"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:textSize="9.5sp"
                android:textStyle="bold"
                android:letterSpacing="0.16" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFaqs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_semi_transparent"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp">

                    <LinearLayout
                        android:id="@+id/llFaqsList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <!-- Populated programmatically with accordion QAs -->
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recipe List Title (For bundle types) -->
            <TextView
                android:id="@+id/tvRecipesHeader"
                style="@style/Text.16x.Manrope.Bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Recipes in this bundle"
                android:textColor="@color/white"
                android:visibility="gone" />

            <!-- Recipes recycler view -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecipes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                tools:listitem="@layout/item_why_product" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Translucent Bottom CTA overlay bar matching design -->
    <View
        android:id="@+id/vBottomGradient"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="@drawable/bg_footer_gradient"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:id="@+id/llCtaBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Buy on Humotron Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBuyOnHumotron"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_btn_lime_pill"
            android:text="Buy on Humotron →"
            android:textColor="#050808"
            android:fontFamily="sans-serif-black"
            android:textSize="14sp"
            android:textAllCaps="false" />

        <!-- See Retailers Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSeeRetailers"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_outline_white"
            android:text="See retailers"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-medium"
            android:textSize="14sp"
            android:textAllCaps="false" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
