<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.splash.SplashActivity">

    <include layout="@layout/bg_main" />

    <LinearLayout
        android:id="@+id/ll_splash_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.humotron.app.ui.decode.view.RadarAnimationView
            android:id="@+id/v_splash_graphic"
            android:layout_width="170dp"
            android:layout_height="170dp" />

        <ImageView
            android:id="@+id/iv_humotron_logo"
            android:layout_width="230dp"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:layout_marginTop="20dp"
            android:adjustViewBounds="true"
            app:tint="@android:color/white"
            android:src="@drawable/ic_logo_onboard" />

        <TextView
            android:id="@+id/tv_splash_subtitle"
            style="@style/Text.14x.Manrope.Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:letterSpacing="0.05"
            android:text="@string/label_splash_subtitle"
            android:textColor="@color/textColorHint" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>