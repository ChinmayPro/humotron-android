<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="@drawable/ic_bg_main_2"
    tools:context=".ui.connect.RingConnectionFragment">

    <include
        android:id="@+id/header"
        layout="@layout/layout_header_3" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvDeviceIcon"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginStart="@dimen/_20dp"
        app:cardBackgroundColor="#1AC4F23E"
        app:cardCornerRadius="17dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header"
        app:strokeColor="#52C4F23E"
        app:strokeWidth="1dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivRingIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            app:srcCompat="@drawable/ic_ring_vector"
            app:tint="#C4F23E" />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvDeviceTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_20dp"
        android:fontFamily="@font/manrope_extra_bold"
        android:text="@string/device_title_ring"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@+id/cvDeviceIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/cvDeviceIcon"
        app:layout_constraintTop_toTopOf="@+id/cvDeviceIcon" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvDeviceStatus"
        style="@style/Text.OnBoard.Sub.Medium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_14dp"
        android:text="@string/device_found_tap_to"
        android:textColor="@color/ink2"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/cvDeviceIcon"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginTop="@dimen/_14dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/_10dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/btnSubmit"
        app:layout_constraintTop_toBottomOf="@id/tvDeviceStatus"
        tools:itemCount="3"
        tools:listitem="@layout/item_ring_device"
        tools:visibility="gone" />

    <LinearLayout
        android:id="@+id/llAnimationView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/btnSubmit"
        app:layout_constraintTop_toBottomOf="@id/tvDeviceStatus">

        <com.humotron.app.view.HdevRingView
            android:id="@+id/scanAnimationView"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/_60dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:scanProgress="0"
            app:scanColor="@color/lime"
            app:scanProgressMargin="35dp" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:text="Connecting your Ring"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvSubtitleStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10dp"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/searching_for_your_ring"
            android:textColor="#F0F4F4"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/llBluetoothStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivBluetoothIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                app:srcCompat="@drawable/ic_bluetooth_24px"
                app:tint="@color/lime" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvBluetoothInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:text="@string/bt_keep_your_device_nearby"
                android:textColor="@color/ink4"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmit"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginBottom="10dp"
        android:fontFamily="@font/manrope_bold"
        android:text="@string/connect"
        android:textAllCaps="false"
        android:textColor="@color/ink2"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="@color/white05"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toTopOf="@+id/footerDisclaimerTextView"
        tools:visibility="visible" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/footerDisclaimerTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:text="@string/if_you_don_t_see_your_device"
        android:textColor="#879A9C"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/tvScanAgain"
        tools:visibility="visible" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvScanAgain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_20dp"
        android:layout_marginBottom="12dp"
        android:fontFamily="@font/manrope_semibold"
        android:gravity="center"
        android:paddingVertical="7dp"
        android:text="@string/scan_again"
        android:textColor="@color/ink3"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>