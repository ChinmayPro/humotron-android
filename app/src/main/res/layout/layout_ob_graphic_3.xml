<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/llShieldBox"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_ob_shield_box"
            android:gravity="center">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_onboard_shield" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/Text.11x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ob_pill_you"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="@string/ob_graphic_3_you"
                android:textColor="@color/insights_subtitle_grey" />

            <TextView
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/ob_graphic_3_arrow"
                android:textColor="@color/insights_light_green" />

            <TextView
                style="@style/Text.11x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ob_pill_humotron"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="@string/ob_graphic_3_humotron"
                android:textColor="@color/insights_light_green" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_onboard_cross" />

            <TextView
                style="@style/Text.11x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ob_pill_partner"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:singleLine="true"
                android:text="@string/ob_graphic_3_partner"
                android:textColor="@color/textColorHint" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
