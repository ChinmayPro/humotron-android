<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/bg_support_category_card"
    android:orientation="vertical"
    android:padding="16dp">


    <FrameLayout
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_support_doc_icon">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivCategoryIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:tint="@color/colorBgBtn1" />

    </FrameLayout>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvCategoryTitle"
        style="@style/Text.14x.Manrope.Bold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/manrope_bold"
        app:fontFamily="@font/manrope_bold"
        android:textStyle="bold"
        android:layout_marginTop="12dp" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvCategoryDesc"
        style="@style/Text.12x.Manrope.Regular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/manrope_medium"
        app:fontFamily="@font/manrope_medium"
        android:layout_marginTop="6dp"
        android:textSize="11sp"
        android:textColor="@color/ink3" />

</LinearLayout>
