<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.profile.RecipeGeneratorFragment">

    <include
        android:id="@+id/header"
        layout="@layout/layout_header_2"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="16dp">

            <!-- Intro Section -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_rounded_14"
                android:backgroundTint="#19C4F23E"
                android:gravity="center">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    android:src="@drawable/ic_bowl"
                    app:tint="#C4F23E" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text.OnBoard.Title1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="Recipe Generator"
                android:textSize="21sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.5"
                android:text="Tune how Humotron builds your plan. These filters shape every meal we suggest to move your metrics."
                android:textColor="#A0B3AF"
                android:textSize="13sp" />

            <!-- How simple should recipes be? -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="How simple should recipes be?"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="Pick the effort level that suits you."
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_style_chip" android:id="@+id/chipSimpleEasy" />
                <include layout="@layout/item_insight_style_chip" android:id="@+id/chipSimpleMedium" />
                <include layout="@layout/item_insight_style_chip" android:id="@+id/chipSimpleModerate" />
                <include layout="@layout/item_insight_style_chip" android:id="@+id/chipSimpleSuperEasy" />
            </com.google.android.flexbox.FlexboxLayout>

            <!-- How much time do you have? -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="How much time do you have?"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="Per meal, start to plate."
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTime5" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTime10" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTime15" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTime20" />
            </com.google.android.flexbox.FlexboxLayout>

            <!-- Dietary preference -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="Dietary preference"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="We'll only suggest meals that fit."
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_chip" android:id="@+id/chipDietNone" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipDietVegan" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipDietOmnivore" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipDietVegetarian" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipDietPescatarian" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipDietVeganOption" />
            </com.google.android.flexbox.FlexboxLayout>
            
            <!-- Exclude ingredients -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="Exclude ingredients"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="Anything you avoid or react to."
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_chip" android:id="@+id/chipExclNut" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipExclNone" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipExclDairy" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipExclGluten" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipExclGlutenOption" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipExclGlutenWrap" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipExclGlutenBread" />
            </com.google.android.flexbox.FlexboxLayout>
            
            <!-- Cuisine -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="Cuisine"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="Lean your plan towards a style."
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_chip" android:id="@+id/chipCuisineAsian" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipCuisineIndian" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipCuisineGlobal" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipCuisineMediterranean" />
            </com.google.android.flexbox.FlexboxLayout>
            
            <!-- Taste preference -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/manrope_extra_bold"
                android:text="Taste preference"
                android:textColor="#ffffff"
                android:textSize="16.5sp"
                android:textStyle="bold"
                app:fontFamily="@font/manrope_extra_bold" />
                
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/manrope_regular"
                android:text="Flavours you gravitate to."
                android:textColor="#8EA09E"
                android:textSize="12.5sp"
                app:fontFamily="@font/manrope_regular" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTasteLight" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTasteSpicy" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTasteSweet" />
                <include layout="@layout/item_insight_chip" android:id="@+id/chipTasteSavory" />
            </com.google.android.flexbox.FlexboxLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Gradient Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_bottom_fade"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Save Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSaveRecipeGen"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="22dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_btn_lime_pill"
        android:text="Save preferences"
        android:textAllCaps="false"
        android:textColor="#0d1618"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
