<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:background="@drawable/ic_bg_main"
    tools:context=".ui.onboarding.personalize.WidthHeightFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTitle"
            style="@style/Text.OnBoard.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_24dp"
            android:layout_marginTop="@dimen/_50dp"
            android:text="@string/nice_to_meet_you"
            android:textColor="@color/white"
            android:textSize="27sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSubtitle"
            style="@style/Text.OnBoard.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_6dp"
            android:layout_marginBottom="24dp"
            android:paddingStart="@dimen/_24dp"
            android:paddingEnd="@dimen/_48dp"
            android:text="@string/desc_width_height"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvHeight"
            style="@style/Text.OnBoard.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_40dp"
            android:paddingStart="@dimen/_24dp"
            android:paddingEnd="@dimen/_48dp"
            android:text="@string/height"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

        <LinearLayout
            android:id="@+id/llHeightContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_24dp"
            android:layout_marginTop="@dimen/_10dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvHeight">

            <LinearLayout
                android:layout_width="128dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_et_login"
                android:orientation="horizontal"
                android:padding="3dp">

                <TextView
                    android:id="@+id/tvHeightCm"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_active"
                    android:fontFamily="@font/manrope_semibold"
                    android:gravity="center"
                    android:text="@string/cm"
                    android:textColor="@color/colorBgBtn" />

                <TextView
                    android:id="@+id/tvHeightFt"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_semibold"
                    android:gravity="center"
                    android:text="@string/ft"
                    android:textColor="@color/white" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etHeightSelect"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:background="@drawable/bg_et_login"
                android:fontFamily="@font/manrope_semibold"
                android:hint="178"
                android:inputType="numberDecimal"
                android:paddingHorizontal="@dimen/_24dp"
                android:textColor="@color/white"
                android:textColorHint="@color/white50"
                android:textSize="16sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/etHeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:ignore="MissingConstraints" />

        <TextView
            android:id="@+id/tvHeightInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:ignore="MissingConstraints" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvWeight"
            style="@style/Text.OnBoard.Sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20dp"
            android:paddingStart="@dimen/_24dp"
            android:paddingEnd="@dimen/_48dp"
            android:text="@string/weight"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llHeightContainer" />

        <LinearLayout
            android:id="@+id/llWeightContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_24dp"
            android:layout_marginTop="@dimen/_10dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvWeight">

            <LinearLayout
                android:layout_width="128dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_et_login"
                android:orientation="horizontal"
                android:padding="3dp">

                <TextView
                    android:id="@+id/tvWeightKg"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_active"
                    android:fontFamily="@font/manrope_semibold"
                    android:gravity="center"
                    android:text="@string/kg"
                    android:textColor="@color/colorBgBtn" />

                <TextView
                    android:id="@+id/tvWeightLb"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_semibold"
                    android:gravity="center"
                    android:text="@string/lb"
                    android:textColor="@color/white" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etWeightSelect"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:background="@drawable/bg_et_login"
                android:fontFamily="@font/manrope_semibold"
                android:hint="74"
                android:inputType="numberDecimal"
                android:paddingHorizontal="@dimen/_24dp"
                android:textColor="@color/white"
                android:textColorHint="@color/white50"
                android:textSize="16sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/etWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:ignore="MissingConstraints" />

        <TextView
            android:id="@+id/tvWeightInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:ignore="MissingConstraints" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSubmit"
            style="@style/Text.16x.Manrope.SemiBold"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="@dimen/_24dp"
            android:layout_marginTop="@dimen/_50dp"
            android:layout_marginBottom="26dp"
            android:background="@drawable/bg_btn_round_corner"
            android:backgroundTint="@color/btn_continue"
            android:text="@string/_continue"
            android:textAllCaps="false"
            android:textColor="@color/btn_text_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1" />


    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.core.widget.NestedScrollView>