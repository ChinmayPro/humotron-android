<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chipRoot"
    android:layout_width="46dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_day_chip_default"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="9dp"
    android:paddingBottom="8dp"
    android:layout_marginEnd="8dp">

    <!-- Day abbreviation (THU, FRI, etc.) -->
    <TextView
        android:id="@+id/tvDayOfWeek"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/manrope_bold"
        android:letterSpacing="0.05"
        android:text="THU"
        android:textAllCaps="true"
        android:textColor="@color/deep_dives_ink4"
        android:textSize="9sp"
        android:textStyle="bold" />

    <!-- Date number -->
    <TextView
        android:id="@+id/tvDateNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:fontFamily="@font/manrope_bold"
        android:text="8"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Zone color dot -->
    <View
        android:id="@+id/dotZone"
        android:layout_width="7dp"
        android:layout_height="7dp"
        android:layout_marginTop="7dp"
        android:background="@drawable/bg_dot_circle" />

</LinearLayout>