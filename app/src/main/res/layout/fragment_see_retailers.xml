<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_back_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            style="@style/Text.16x.Manrope.Bold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="See retailers"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- Matched to biology eyebrow -->
            <TextView
                style="@style/Text.10x.Manrope.Bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="22dp"
                android:fontFamily="monospace"
                android:text="Matched to your biology"
                android:textColor="#C4F23E"
                android:textAllCaps="true"
                android:letterSpacing="0.16" />

            <!-- Product Title -->
            <TextView
                android:id="@+id/tvProductTitle"
                style="@style/Text.22x.Manrope.Bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_horizontal"
                android:textColor="@color/white"
                tools:text="Magnesium Glycinate 400mg" />

            <!-- Match Progress Ring -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp">

                <!-- Flat Background Track Ring -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_track_ring_flat" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/pbMatchRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:max="100"
                    android:progress="91"
                    app:indicatorColor="#C4F23E"
                    app:trackColor="@android:color/transparent"
                    app:trackThickness="9dp"
                    app:indicatorSize="108dp"
                    app:trackCornerRadius="5dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvMatchPercent"
                        style="@style/Text.24x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="91%"
                        android:textColor="@color/white" />

                    <TextView
                        style="@style/Text.10x.Manrope.Bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MATCH"
                        android:textColor="#8A9594"
                        android:textAllCaps="true"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </FrameLayout>

            <!-- Privacy Policy Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_privacy_card"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <!-- Diamond char symbol -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◇"
                    android:textColor="#C4F23E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/tvPrivacyText"
                    style="@style/Text.12x.Manrope.Medium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingMultiplier="1.5"
                    android:textColor="#bcd98a"
                    tools:text="Your data stays with Humotron. We pass the match to the retailer — never your health signals." />

            </LinearLayout>

            <!-- AVAILABLE FROM section label with line -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Available from"
                    android:textColor="#7C8B89"
                    android:textSize="9.5sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="#10FFFFFF" />

            </LinearLayout>

            <!-- Retailers List Cards -->
            <LinearLayout
                android:id="@+id/llRetailersList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <!-- Thorne Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardThorne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_semi_transparent"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_retailer_logo"
                            android:text="💊"
                            android:textSize="18sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.14x.Manrope.Bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thorne"
                                android:textColor="@color/white" />

                            <TextView
                                style="@style/Text.11x.Manrope.SemiBold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Free delivery · 2 days"
                                android:textColor="#8A9594" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.15x.Manrope.Bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="£24"
                                android:textColor="@color/white" />

                            <TextView
                                style="@style/Text.11x.Manrope.Bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Buy →"
                                android:textColor="#C4F23E" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Pure Encapsulations Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPure"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_semi_transparent"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_retailer_logo"
                            android:text="🧪"
                            android:textSize="18sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.14x.Manrope.Bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pure Encapsulations"
                                android:textColor="@color/white" />

                            <TextView
                                style="@style/Text.11x.Manrope.SemiBold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Next-day delivery"
                                android:textColor="#8A9594" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.15x.Manrope.Bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="£27"
                                android:textColor="@color/white" />

                            <TextView
                                style="@style/Text.11x.Manrope.Bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Buy →"
                                android:textColor="#C4F23E" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Holland & Barrett Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHolland"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_semi_transparent"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_retailer_logo"
                            android:text="🌿"
                            android:textSize="18sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.14x.Manrope.Bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Holland &amp; Barrett"
                                android:textColor="@color/white" />

                            <TextView
                                style="@style/Text.11x.Manrope.SemiBold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="In stock · collect today"
                                android:textColor="#8A9594" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.15x.Manrope.Bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="£19"
                                android:textColor="@color/white" />

                            <TextView
                                style="@style/Text.11x.Manrope.Bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Buy →"
                                android:textColor="#C4F23E" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Price disclaimer note -->
            <TextView
                style="@style/Text.11x.Manrope.SemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_horizontal"
                android:text="Prices indicative · partners may vary by region."
                android:textColor="#8A9594" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
