<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:background="@color/black"
    tools:context=".ui.decode.DecodeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvInsightsTitle"
            style="@style/Text.20x.Manrope.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/insights"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/llTabIcons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/tabInsights"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivInsights"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_decode"
                    app:tint="@color/colorBgBtn" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvInsights"
                    style="@style/Text.10x.Manrope.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_3dp"
                    android:text="@string/insights"
                    android:textColor="@color/colorBgBtn" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabDeepDives"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivDeepDives"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_deep_dives"
                    app:tint="@color/white30" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvDeepDives"
                    style="@style/Text.10x.Manrope.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_3dp"
                    android:text="@string/deep_dives"
                    android:textColor="@color/white30" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabOptimize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivOptimize"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_optimize"
                    app:tint="@color/white30" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvOptimize"
                    style="@style/Text.10x.Manrope.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_3dp"
                    android:text="@string/optimize"
                    android:textColor="@color/white30" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivChat"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_chat"
                    app:tint="@color/white30" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvChat"
                    style="@style/Text.10x.Manrope.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_3dp"
                    android:text="@string/chat"
                    android:textColor="@color/white30" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/_5dp"
        android:background="@color/white10"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

</androidx.constraintlayout.widget.ConstraintLayout>
