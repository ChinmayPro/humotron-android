<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_bg_main" />

    <!-- Top Sticky Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnBack"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_back_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnShare"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:alpha="0.6"
                android:padding="4dp"
                android:src="@drawable/ic_share"
                app:tint="@color/white" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnLike"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="10dp"
                android:alpha="0.6"
                android:padding="4dp"
                android:src="@drawable/ic_fav_checkbox"
                app:tint="@color/white" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/layoutLoader"
        layout="@layout/layout_bar_loader"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clTopBar" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvNoData"
        style="@style/Text.16x.Manrope.SemiBold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_data_found"
        android:textColor="@color/white50"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clTopBar" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/clBottom"
        app:layout_constraintTop_toBottomOf="@id/clTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

            <!-- Product Image Section -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivProduct"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="20dp"
                android:scaleType="centerInside" />

            <View
                android:id="@+id/indicator"
                android:layout_width="32dp"
                android:layout_height="8dp"
                android:layout_marginTop="12dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_gallery_indicator_active" />

            <!-- Category -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvCategory"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="DIETARY SUPPLEMENT"
                android:textAllCaps="true"
                android:textColor="@color/white70" />

            <!-- Product Name -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvProductName"
                style="@style/Text.24x.Manrope.Bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="58dp"
                android:textColor="@color/white"
                tools:text="Omega-3 Fish Oil" />

            <!-- Price -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPrice"
                style="@style/Text.20x.Manrope.Bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="@color/white"
                tools:text="£ 25.99" />

            <!-- Brand -->
            <LinearLayout
                android:id="@+id/llBrand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text.14x.Manrope.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By: "
                    android:textColor="@color/white50" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvBrand"
                    style="@style/Text.14x.Manrope.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white70"
                    tools:text="Nutrisule" />

            </LinearLayout>

            <!-- Pack Size -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPackSize"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/s300"
                tools:text="Pack Size: 60 capsules / 1-month supply" />

            <!-- Description -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDescription"
                style="@style/Text.14x.Manrope.Regular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/white40"
                tools:text="Description text..." />

            <!-- Info Cards Section (Restored) -->
            <LinearLayout
                android:id="@+id/llInfoCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <!-- Daily Servings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDailyServings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white10"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/_10dp"
                        android:paddingHorizontal="@dimen/_20dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvDailyServingsValue"
                            style="@style/Text.18x.Manrope.Bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/white"
                            tools:text="2 capsules da..." />

                        <androidx.appcompat.widget.AppCompatTextView
                            style="@style/Text.12x.Manrope.Medium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Daily Servings"
                            android:textColor="@color/s300" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Supply Duration Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSupplyDuration"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white10"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/_10dp"
                        android:paddingHorizontal="@dimen/_20dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvSupplyDurationValue"
                            style="@style/Text.18x.Manrope.Bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            tools:text="30 days" />

                        <androidx.appcompat.widget.AppCompatTextView
                            style="@style/Text.12x.Manrope.Medium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Supply Duration"
                            android:textColor="@color/s300" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Suggestions Section -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvSuggestionsHeader"
                style="@style/Text.14x.Manrope.Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="Suggestions for optimal results:"
                android:textColor="@color/white50"
                app:layout_constraintTop_toBottomOf="@id/llInfoCards" />

            <LinearLayout
                android:id="@+id/llSuggestionsCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvSuggestionsHeader">

                <!-- Course Length Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCourseLength"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white10"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/_10dp"
                        android:paddingHorizontal="@dimen/_20dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvCourseLengthValue"
                            style="@style/Text.18x.Manrope.Bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            tools:text="90 days" />

                        <androidx.appcompat.widget.AppCompatTextView
                            style="@style/Text.12x.Manrope.Medium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Course Length"
                            android:textColor="@color/s300" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- When to take Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWhenToTake"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white10"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/_10dp"
                        android:paddingHorizontal="@dimen/_20dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvWhenToTakeValue"
                            style="@style/Text.18x.Manrope.Bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            tools:text="Meal" />

                        <androidx.appcompat.widget.AppCompatTextView
                            style="@style/Text.12x.Manrope.Medium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="When to take?"
                            android:textColor="@color/s300" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Expandable Sections -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="vertical">

                <!-- Usage Instructions -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardUsageInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/black"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/white10"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/clUsageHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <androidx.appcompat.widget.AppCompatTextView
                                style="@style/Text.16x.Manrope.Medium"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Usage Instructions"
                                android:textColor="@color/white70" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivUsageArrow"
                                android:layout_width="7dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_right_arrow"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/white50" />

                        </LinearLayout>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvUsageContent"
                            style="@style/Text.14x.Manrope.Regular"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/white50"
                            android:visibility="gone"
                            tools:text="• When to Take: Best taken with a meal...\n• How to Take: Take 2 capsules..."
                            tools:visibility="visible" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Key Ingredients -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardKeyIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/black"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/white10"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/clIngredientsHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <androidx.appcompat.widget.AppCompatTextView
                                style="@style/Text.16x.Manrope.Medium"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Key Ingredients"
                                android:textColor="@color/white70" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivIngredientsArrow"
                                android:layout_width="7dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_right_arrow"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/white50" />

                        </LinearLayout>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvIngredientsContent"
                            style="@style/Text.14x.Manrope.Regular"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/white50"
                            android:visibility="gone"
                            tools:text="• Ingredient 1: Description...\n• Ingredient 2: Description..." />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- How It Works -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHowItWorks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/black"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/white10"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/clHowItWorksHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <androidx.appcompat.widget.AppCompatTextView
                                style="@style/Text.16x.Manrope.Medium"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How It Works"
                                android:textColor="@color/white70" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivHowItWorksArrow"
                                android:layout_width="7dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_right_arrow"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/white50" />

                        </LinearLayout>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvHowItWorksContent"
                            style="@style/Text.14x.Manrope.Regular"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/white50"
                            android:visibility="gone"
                            tools:text="Description of how it works..." />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Frequently Asked Questions -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFaq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/black"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/white10"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/clFaqHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <androidx.appcompat.widget.AppCompatTextView
                                style="@style/Text.16x.Manrope.Medium"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Frequently Asked Questions"
                                android:textColor="@color/white70" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivFaqArrow"
                                android:layout_width="18dp"
                                android:layout_height="21dp"
                                android:src="@drawable/ic_book_summary"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/white50" />

                        </LinearLayout>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvFaqContent"
                            style="@style/Text.14x.Manrope.Regular"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/white50"
                            android:visibility="gone"
                            tools:text="Q: Question?\nA: Answer..." />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            </LinearLayout>

            <!-- Why Product? Section -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvWhyProductHeader"
                style="@style/Text.18x.Manrope.Bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:paddingHorizontal="20dp"
                android:text="Why Product?"
                android:textColor="@color/white" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWhyProduct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_why_product" />

            <!-- Chat Prompts Section -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvChatPrompts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_chat_prompt" />


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Buy Now Button Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBuyNow"
            style="@style/Text.16x.Manrope.SemiBold"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_btn_round_corner"
            android:text="Buy Now →"
            android:textAllCaps="false"
            android:textColor="@color/black"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
