<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="3dp">

    <!-- Zone label -->
    <TextView
        android:id="@+id/tvZoneLabel"
        style="@style/Text.11x.Manrope.SemiBold"
        android:layout_width="74dp"
        android:layout_height="wrap_content"
        tools:text="@string/thriving"
        android:textColor="@color/deep_dives_ink2" />

    <!-- Track -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_weight="1"
        android:background="@drawable/bg_zone_track">

        <!-- Fill -->
        <View
            android:id="@+id/viewZoneFill"
            android:layout_width="0dp"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- Percentage -->
    <TextView
        android:id="@+id/tvZonePercent"
        style="@style/Text.10x.Manrope.Regular"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        tools:text="44%"
        android:textColor="@color/deep_dives_ink3" />

</LinearLayout>
