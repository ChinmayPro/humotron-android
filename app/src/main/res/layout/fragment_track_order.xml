                            android:visibility="invisible"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="@id/tvStatusNameDelivered"
                            app:layout_constraintTop_toBottomOf="@id/tvStatusNameDelivered" />
