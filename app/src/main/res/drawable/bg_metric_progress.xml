<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Track -->
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="#20FFFFFF" /> <!-- Subtle 12.5% opacity white for the track -->
            <corners android:radius="3dp" />
        </shape>
    </item>

    <!-- Progress Track -->
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <solid android:color="#8a9794" /> <!-- Sleek grey progress color -->
                <corners android:radius="3dp" />
            </shape>
        </clip>
    </item>
</layer-list>
