<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Selected -->
    <item android:state_checked="true">
        <shape>
            <solid android:color="#B8FF4F"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- Unselected -->
    <item>
        <shape>
            <solid android:color="#1E1E1E"/>
            <stroke
                android:width="1dp"
                android:color="#444444"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

</selector>
