<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer halo: 17dp diameter -->
    <item android:width="17dp" android:height="17dp">
        <shape android:shape="oval">
            <solid android:color="#1EFFFFFF" />
        </shape>
    </item>
    <!-- Inner white dot: 9dp diameter, centered (inset 4dp) -->
    <item
        android:top="4dp"
        android:left="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
