<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Ring -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="@color/colorBgBtn1" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <!-- Inner Solid Dot -->
    <item
        android:bottom="5dp"
        android:left="5dp"
        android:right="5dp"
        android:top="5dp">
        <shape android:shape="oval">
            <solid android:color="@color/colorBgBtn1" />
        </shape>
    </item>
</layer-list>
