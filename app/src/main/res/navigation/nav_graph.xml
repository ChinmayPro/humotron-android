<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/app_main"
    app:startDestination="@id/fragmentTrack">

    <fragment
        android:id="@+id/fragmentTrack"
        android:name="com.humotron.app.ui.track.TrackFragment"
        tools:layout="@layout/fragment_track">
        <action
            android:id="@+id/action_fragmentTrack_to_fragmentUploadedReports"
            app:destination="@id/fragmentUploadedReports"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDecode"
        android:name="com.humotron.app.ui.decode.DecodeFragment"
        tools:layout="@layout/fragment_decode" />

    <fragment
        android:id="@+id/fragmentBioHack"
        android:name="com.humotron.app.ui.bioHack.BioHackMainFragment" />

    <fragment
        android:id="@+id/fragmentConnectInfo"
        android:name="com.humotron.app.ui.connect.ConnectInfoFragment" />

    <fragment
        android:id="@+id/fragmentDeviceConnection"
        android:name="com.humotron.app.ui.connect.DeviceConnectionFragment" />

    <fragment
        android:id="@+id/fragmentBandConnection"
        android:name="com.humotron.app.ui.connect.BandConnectionFragment" />

    <fragment
        android:id="@+id/fragmentDeviceConnected"
        android:name="com.humotron.app.ui.connect.DeviceConnectedFragment" />

    <fragment
        android:id="@+id/fragmentDeviceData"
        android:name="com.humotron.app.ui.device.DeviceDataFragment">
        <action
            android:id="@+id/action_fragmentDeviceData_to_fragmentMetricDetails"
            app:destination="@id/fragmentMetricDetails" />
    </fragment>

    <fragment
        android:id="@+id/fragmentMetric"
        android:name="com.humotron.app.ui.device.MetricFragment" />
     <fragment
        android:id="@+id/assessmentFragment"
         android:name="com.humotron.app.ui.assesment.AssessmentFragment"
         android:label="Assessment" />
    <fragment
        android:id="@+id/fragmentMetricDetails"
        android:name="com.humotron.app.ui.metrics.MetricDetailsFragment">
        <argument
            android:name="metric"
            app:argType="com.humotron.app.domain.modal.response.MetricType" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDecodeMetrics"
        android:name="com.humotron.app.ui.decode.DecodeMetricsFragment"
        tools:layout="@layout/fragment_decode_metrics" />

    <fragment
        android:id="@+id/fragmentDecodeQuestions"
        android:name="com.humotron.app.ui.decode.DecodeQuestionsFragment"
        tools:layout="@layout/fragment_decode_questions">
        <argument
            android:name="type"
            app:argType="string" />
        <argument
            android:name="title"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/fragmentUploadedReports"
        android:name="com.humotron.app.ui.bloodTest.UploadedReportsFragment"
        android:label="Uploaded Reports"
        tools:layout="@layout/fragment_uploaded_reports" />

    <fragment
        android:id="@+id/fragmentProfile"
        android:name="com.humotron.app.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_fragmentProfile_to_nav_graph_shop"
            app:destination="@id/nav_graph_shop"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <include app:graph="@navigation/nav_graph_shop" />

    <fragment
        android:id="@+id/fragmentShopDeviceDetails"
        android:name="com.humotron.app.ui.shop.ShopDeviceDetailsFragment"
        android:label="Device Details">
        <argument
            android:name="device"
            app:argType="com.humotron.app.domain.modal.response.GetShopDevicesResponse$Device" />
    </fragment>

</navigation>