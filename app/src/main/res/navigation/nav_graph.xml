<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/app_main"
    app:startDestination="@id/fragmentTrack">

    <fragment
        android:id="@+id/fragmentTrack"
        android:name="com.humotron.app.ui.track.TrackFragment"
        tools:layout="@layout/fragment_track">
        <action
            android:id="@+id/action_fragmentTrack_to_fragmentUploadedReports"
            app:destination="@id/fragmentUploadedReports"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDecode"
        android:name="com.humotron.app.ui.decode.DecodeFragment"
        tools:layout="@layout/fragment_decode">
        <action
            android:id="@+id/action_fragmentDecode_to_fragmentDecodePatternWindow"
            app:destination="@id/fragmentDecodePatternWindow"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_fragmentDecode_to_fragmentWorkdayReport"
            app:destination="@id/fragmentWorkdayReport"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_fragmentDecode_to_fragmentWeatherOverview"
            app:destination="@id/fragmentWeatherOverview"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Deep Dives Flow -->
    <fragment
        android:id="@+id/fragmentWorkdayReport"
        android:name="com.humotron.app.ui.decode.DecodeWorkdayReportFragment"
        tools:layout="@layout/fragment_workday_report">
        <action
            android:id="@+id/action_fragmentWorkdayReport_to_fragmentWorkdayDetails"
            app:destination="@id/fragmentWorkdayDetails"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/fragmentWorkdayDetails"
        android:name="com.humotron.app.ui.decode.DecodeWorkdayDetailsFragment"
        tools:layout="@layout/fragment_workday_details" />

    <fragment
        android:id="@+id/fragmentWeatherOverview"
        android:name="com.humotron.app.ui.decode.DecodeWeatherOverviewFragment"
        tools:layout="@layout/fragment_weather_overview">
        <action
            android:id="@+id/action_fragmentWeatherOverview_to_fragmentWeatherDetail"
            app:destination="@id/fragmentWeatherDetail"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/fragmentWeatherDetail"
        android:name="com.humotron.app.ui.decode.DecodeWeatherDetailFragment"
        tools:layout="@layout/fragment_weather_detail">
        <argument
            android:name="weatherId"
            app:argType="string"
            android:defaultValue="a" />
    </fragment>

    <fragment
        android:id="@+id/fragmentBioHack"
        android:name="com.humotron.app.ui.bioHack.BioHackMainFragment" />

    <fragment
        android:id="@+id/fragmentConnectInfo"
        android:name="com.humotron.app.ui.connect.ConnectInfoFragment" />

    <fragment
        android:id="@+id/fragmentRingConnection"
        android:name="com.humotron.app.ui.connect.RingConnectionFragment" />

    <fragment
        android:id="@+id/fragmentBandConnection"
        android:name="com.humotron.app.ui.connect.BandConnectionFragment" />

    <fragment
        android:id="@+id/fragmentBPMachineConnection"
        android:name="com.humotron.app.ui.connect.BPMachineConnectionFragment" />

    <fragment
        android:id="@+id/fragmentWeightMachineConnection"
        android:name="com.humotron.app.ui.connect.WeightMachineConnectionFragment" />

    <fragment
        android:id="@+id/fragmentDeviceConnected"
        android:name="com.humotron.app.ui.connect.DeviceConnectedFragment">
        <argument
            android:name="deviceMetaData"
            android:defaultValue="@null"
            app:argType="com.humotron.app.domain.modal.param.DeviceMetaDataParam"
            app:nullable="true" />
        <argument
            android:name="deviceType"
            app:argType="com.humotron.app.domain.modal.DeviceType" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDeviceData"
        android:name="com.humotron.app.ui.device.DeviceDataFragment">
        <action
            android:id="@+id/action_fragmentDeviceData_to_fragmentMetricDetails"
            app:destination="@id/fragmentMetricDetails" />
        <action
            android:id="@+id/action_fragmentDeviceData_to_fragmentWeightScaleReading"
            app:destination="@id/fragmentWeightScaleReading" />
    </fragment>

    <fragment
        android:id="@+id/fragmentWeightScaleReading"
        android:name="com.humotron.app.ui.device.WeightScaleReadingFragment"
        tools:layout="@layout/fragment_weight_scale_reading">
        <argument
            android:name="wearable"
            app:argType="com.humotron.app.domain.modal.response.GetAllDeviceResponse$Data$UserDevice"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/fragmentBPMachineReading"
        android:name="com.humotron.app.ui.device.BPMachineReadingFragment"
        tools:layout="@layout/fragment_bp_machine_reading">
        <argument
            android:name="wearable"
            app:argType="com.humotron.app.domain.modal.response.GetAllDeviceResponse$Data$UserDevice"
            app:nullable="true" />
        <argument
            android:name="readingType"
            app:argType="com.humotron.app.domain.modal.BPMachineReadingType" />
    </fragment>

    <fragment
        android:id="@+id/fragmentMetric"
        android:name="com.humotron.app.ui.device.MetricFragment">
        <action
            android:id="@+id/action_fragmentMetric_to_fragmentDecodeChat"
            app:destination="@id/fragmentDecodeChat" />
    </fragment>

    <fragment
        android:id="@+id/assessmentFragment"
        android:name="com.humotron.app.ui.assesment.AssessmentFragment"
        android:label="Assessment" />

    <fragment
        android:id="@+id/fragmentMetricDetails"
        android:name="com.humotron.app.ui.metrics.MetricDetailsFragment">
        <argument
            android:name="metric"
            app:argType="com.humotron.app.domain.modal.response.MetricType" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDecodeMetrics"
        android:name="com.humotron.app.ui.decode.DecodeMetricsFragment"
        tools:layout="@layout/fragment_decode_metrics" />

    <fragment
        android:id="@+id/fragmentDecodeQuestions"
        android:name="com.humotron.app.ui.decode.DecodeQuestionsFragment"
        tools:layout="@layout/fragment_decode_questions">
        <argument
            android:name="type"
            app:argType="string" />
        <argument
            android:name="title"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDecodeChat"
        android:name="com.humotron.app.ui.decode.DecodeChatFragment"
        tools:layout="@layout/fragment_decode_chat" />

    <fragment
        android:id="@+id/fragmentUploadedReports"
        android:name="com.humotron.app.ui.bloodTest.UploadedReportsFragment"
        android:label="Uploaded Reports"
        tools:layout="@layout/fragment_uploaded_reports" />

    <include app:graph="@navigation/nav_graph_profile" />
    <include app:graph="@navigation/nav_graph_shop" />
    <include app:graph="@navigation/nav_graph_order" />

    <fragment
        android:id="@+id/fragmentCart"
        android:name="com.humotron.app.ui.cart.CartFragment"
        android:label="Cart"
        tools:layout="@layout/fragment_cart">
        <action
            android:id="@+id/action_fragmentCart_to_fragmentShopBuyNow"
            app:destination="@id/fragmentShopBuyNow" />
        <action
            android:id="@+id/action_fragmentCart_to_fragmentOrderSuccess"
            app:destination="@id/fragmentOrderSuccess" />
    </fragment>

    <fragment
        android:id="@+id/fragmentOrderSuccess"
        android:name="com.humotron.app.ui.cart.OrderSuccessFragment"
        android:label="Order Success"
        tools:layout="@layout/fragment_order_success">
        <argument
            android:name="orderId"
            app:argType="string" />
        <action
            android:id="@+id/action_fragmentOrderSuccess_to_fragmentProfile"
            app:destination="@id/fragmentProfile"
            app:popUpTo="@id/app_main"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/fragmentShopBuyNow"
        android:name="com.humotron.app.ui.shop.ShopBuyNowFragment"
        android:label="Buy Now"
        tools:layout="@layout/fragment_shop_buy_now">
        <argument
            android:name="deviceId"
            app:argType="string" />
        <argument
            android:name="cartItemId"
            android:defaultValue=""
            app:argType="string" />
        <argument
            android:name="quantity"
            android:defaultValue="1"
            app:argType="integer" />
        <argument
            android:name="variantId"
            android:defaultValue=""
            app:argType="string" />
        <action
            android:id="@+id/action_fragmentShopBuyNow_to_fragmentCart"
            app:destination="@id/fragmentCart"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"
            app:popUpTo="@id/nav_graph_shop"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/fragmentShopDeviceDetails"
        android:name="com.humotron.app.ui.shop.ShopDeviceDetailsFragment"
        android:label="Device Details">
        <argument
            android:name="device"
            app:argType="com.humotron.app.domain.modal.response.GetShopDevicesResponse$Device" />
        <action
            android:id="@+id/action_fragmentShopDeviceDetails_to_fragmentShopBuyNow"
            app:destination="@id/fragmentShopBuyNow"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/fragmentShopOptimizeDetail"
        android:name="com.humotron.app.ui.shop.ShopOptimizeDetailFragment"
        android:label="Optimize Details">
        <argument
            android:name="supplement"
            android:defaultValue="@null"
            app:argType="com.humotron.app.domain.modal.response.SupplementItem"
            app:nullable="true" />
        <argument
            android:name="recipe"
            android:defaultValue="@null"
            app:argType="com.humotron.app.domain.modal.response.RecipeItem"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/fragmentHealthScan"
        android:name="com.humotron.app.ui.device.HealthScanFragment"
        tools:layout="@layout/fragment_health_scan">
        <argument
            android:name="healthScanItem"
            app:argType="com.humotron.app.ui.device.adapter.HealthScanItem" />
    </fragment>

    <fragment
        android:id="@+id/fragmentPastScans"
        android:name="com.humotron.app.ui.device.PastScansFragment"
        tools:layout="@layout/fragment_past_scans">
        <argument
            android:name="healthScanItem"
            app:argType="com.humotron.app.ui.device.adapter.HealthScanItem" />
    </fragment>

    <fragment
        android:id="@+id/fragmentHealthScanResult"
        android:name="com.humotron.app.ui.device.HealthScanResultFragment"
        tools:layout="@layout/fragment_health_scan_result">
        <argument
            android:name="result"
            app:argType="com.humotron.app.domain.modal.ui.HealthScanResult" />
        <argument
            android:name="healthScanItem"
            app:argType="com.humotron.app.ui.device.adapter.HealthScanItem" />
        <argument
            android:name="baseLine"
            app:argType="float" />
        <argument
            android:name="current"
            app:argType="float" />
        <argument
            android:name="wearable"
            app:argType="com.humotron.app.domain.modal.response.GetAllDeviceResponse$Data$UserDevice"
            app:nullable="true" />
    </fragment>    <fragment
        android:id="@+id/fragmentShopBoosterDetail"
        android:name="com.humotron.app.ui.shop.ShopBoosterDetailFragment"
        android:label="Booster Details"
        tools:layout="@layout/fragment_shop_booster_detail">
        <argument
            android:name="booster"
            app:argType="com.humotron.app.domain.modal.response.BoosterResponse$Booster" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDecodePatternWindow"
        android:name="com.humotron.app.ui.decode.DecodePatternWindowFragment"
        android:label="Pattern Window"
        tools:layout="@layout/fragment_decode_pattern_window">
        <argument
            android:name="metricName"
            app:argType="string" />
        <argument
            android:name="metricId"
            app:argType="string" />
        <action
            android:id="@+id/action_fragmentDecodePatternWindow_to_fragmentDecodeProcessing"
            app:destination="@id/fragmentDecodeProcessing"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_fragmentDecodePatternWindow_to_fragmentDecodeDetail"
            app:destination="@id/fragmentDecodeDetail"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_fragmentDecodePatternWindow_to_fragmentDecodePatterns"
            app:destination="@id/fragmentDecodePatterns"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDecodeProcessing"
        android:name="com.humotron.app.ui.decode.DecodeProcessingFragment"
        android:label="Processing"
        tools:layout="@layout/fragment_decode_processing">
        <argument
            android:name="metricName"
            app:argType="string" />
        <argument
            android:name="metricId"
            app:argType="string" />
        <argument
            android:name="selectedRange"
            app:argType="string" />
        <argument
            android:name="pastWindows"
            app:argType="com.humotron.app.domain.modal.response.TimelineWindow[]" />
        <action
            android:id="@+id/action_fragmentDecodeProcessing_to_fragmentDecodePatterns"
            app:destination="@id/fragmentDecodePatterns"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"
            app:popUpTo="@id/fragmentDecodePatternWindow" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDecodeDetail"
        android:name="com.humotron.app.ui.decode.DecodeDetailFragment"
        android:label="Detail"
        tools:layout="@layout/fragment_decode_detail">
        <argument
            android:name="metricName"
            app:argType="string" />
        <argument
            android:name="insightId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDecodePatterns"
        android:name="com.humotron.app.ui.decode.DecodePatternsFragment"
        android:label="Patterns"
        tools:layout="@layout/fragment_decode_patterns">
        <argument
            android:name="metricName"
            app:argType="string" />
        <argument
            android:name="metricId"
            app:argType="string" />
        <argument
            android:name="selectedRange"
            app:argType="string" />
        <argument
            android:name="pastWindows"
            app:argType="com.humotron.app.domain.modal.response.TimelineWindow[]" />
        <action
            android:id="@+id/action_fragmentDecodePatterns_to_fragmentDecodeDetail"
            app:destination="@id/fragmentDecodeDetail"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/fragmentTronChat"
        android:name="com.humotron.app.ui.decode.TronChatFragment"
        tools:layout="@layout/fragment_tron_chat">
        <argument
            android:name="chat_prompt_id"
            app:argType="string"
            app:nullable="true" />
        <argument
            android:name="chat_prompt_title"
            app:argType="string"
            app:nullable="true" />
        <argument
            android:name="chat_conversation_id"
            app:argType="string"
            app:nullable="true" />
    </fragment>

</navigation>
