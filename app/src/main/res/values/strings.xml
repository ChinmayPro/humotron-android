    <string name="cardiac_test_details_title">Cardiac Biomarker\nTest Details</string>
    <string name="test_overview_title">Test Overview</string>
    <string name="test_overview_desc">Gain comprehensive insights into your heart health with our Cardiac Biomarker Test. This test measures key biomarkers, including LDL (bad cholesterol), HDL (good cholesterol), Triglycerides, and HbA1c, which together offer a detailed picture of your cardiovascular health.</string>
    <string name="purpose_of_test_title">Purpose of Test</string>
    <string name="purpose_of_test_desc">This test is designed to identify risk factors for heart disease and help tailor your health management plan. It\'s a proactive step towards ensuring long-term heart wellness.</string>
    <string name="preparation_for_test_title">Preparation for Test</string>
    <string name="prep_fasting">Fasting Requirement: Yes, fast for at least 8-12 hours before the test for accurate results.</string>
    <string name="prep_medication">Medication: Continue your medications unless your doctor advises otherwise.</string>
    <string name="prep_hydration">Hydration: Drink plenty of water; it helps with sample collection.</string>
    <string name="prep_when_to_test">When to Test: Morning is the ideal time as your body is in a rested state, providing the most stable results.</string>
    <string name="duration_title">Duration</string>
    <string name="duration_desc">The test itself will only take a few minutes, but please allow a 30-minute window for the appointment.</string>
    <string name="results_turnaround_title">Results Turnaround</string>
    <string name="results_turnaround_desc1">You will receive your results within 2-3 business days, with a comprehensive explanation of what they mean for your heart health.</string>
    <string name="results_turnaround_desc2">A follow-up consultation will be scheduled to discuss your results and next steps.</string>
