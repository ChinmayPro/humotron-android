<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="StoryProgressView">
        <attr name="segmentCount" format="integer" /> <!-- Though we set this programmatically -->
        <attr name="segmentGap" format="dimension" />
        <attr name="segmentStrokeWidth" format="dimension" />
        <attr name="segmentCornerRadius" format="dimension" />
        <attr name="segmentColor" format="color" />
        <attr name="progressColor" format="color" />
    </declare-styleable>

    <declare-styleable name="BorderedTextView">
        <attr name="borderColor" format="color" />
        <attr name="cornerRadius" format="dimension" />
        <attr name="borderWidth" format="dimension" />
        <attr name="leftPadding" format="dimension" />
        <attr name="rightPadding" format="dimension" />
        <attr name="topPadding" format="dimension" />
        <attr name="bottomPadding" format="dimension" />
    </declare-styleable>

    <declare-styleable name="InfoCardView">
        <attr name="cardTitle" format="string" />
        <attr name="cardDescription" format="string" />
        <attr name="cardStrokeColor" format="color" />
        <attr name="cardStrokeWidth" format="dimension" />
        <attr name="cardBackgroundColor" format="color" />
    </declare-styleable>

    <declare-styleable name="LayeredCardView">

        <attr name="titleTextSize" format="dimension" />
        <attr name="descriptionTextSize" format="dimension" />
        <attr name="plusTextSize" format="dimension" />

        <attr name="titleTextColor" format="color" />
        <attr name="descriptionTextColor" format="color" />
        <attr name="plusTextColor" format="color" />

        <attr name="titleFontFamily" format="reference|string" />
        <attr name="descriptionFontFamily" format="reference|string" />
        <attr name="plusFontFamily" format="reference|string" />

    </declare-styleable>

    <declare-styleable name="VerticalGaugeView">

        <attr name="minValue" format="float" />
        <attr name="maxValue" format="float" />
        <attr name="step" format="float" />

        <attr name="primaryValue" format="float" />
        <attr name="secondaryValue" format="float" />
        <attr name="highlightTextValue" format="float" />

        <attr name="trackColor" format="color" />
        <attr name="fillColor" format="color" />
        <attr name="textColor" format="color" />
        <attr name="highlightTextColor" format="color" />
        <attr name="secondaryMarkerColor" format="color" />

        <attr name="maxTextSize" format="dimension" />
        <attr name="minTextSize" format="dimension" />

    </declare-styleable>
</resources>