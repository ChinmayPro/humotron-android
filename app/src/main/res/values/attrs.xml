<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="StoryProgressView">
        <attr name="segmentCount" format="integer" /> <!-- Though we set this programmatically -->
        <attr name="segmentGap" format="dimension" />
        <attr name="segmentStrokeWidth" format="dimension" />
        <attr name="segmentCornerRadius" format="dimension" />
        <attr name="segmentColor" format="color" />
        <attr name="progressColor" format="color" />
    </declare-styleable>

    <declare-styleable name="BorderedTextView">
        <attr name="borderColor" format="color" />
        <attr name="cornerRadius" format="dimension" />
        <attr name="borderWidth" format="dimension" />
        <attr name="leftPadding" format="dimension" />
        <attr name="rightPadding" format="dimension" />
        <attr name="topPadding" format="dimension" />
        <attr name="bottomPadding" format="dimension" />
    </declare-styleable>

    <declare-styleable name="InfoCardView">
        <attr name="cardTitle" format="string" />
        <attr name="cardDescription" format="string" />
        <attr name="cardStrokeColor" format="color" />
        <attr name="cardStrokeWidth" format="dimension" />
        <attr name="cardBackgroundColor" format="color" />
    </declare-styleable>

    <declare-styleable name="LayeredCardView">

        <attr name="titleTextSize" format="dimension" />
        <attr name="descriptionTextSize" format="dimension" />
        <attr name="plusTextSize" format="dimension" />

        <attr name="titleTextColor" format="color" />
        <attr name="descriptionTextColor" format="color" />
        <attr name="plusTextColor" format="color" />

        <attr name="titleFontFamily" format="reference|string" />
        <attr name="descriptionFontFamily" format="reference|string" />
        <attr name="plusFontFamily" format="reference|string" />

    </declare-styleable>

    <declare-styleable name="VerticalGaugeView">

        <attr name="minValue" format="float" />
        <attr name="maxValue" format="float" />
        <attr name="step" format="float" />

        <attr name="primaryValue" format="float" />
        <attr name="secondaryValue" format="float" />
        <attr name="highlightTextValue" format="float" />

        <attr name="trackColor" format="color" />
        <attr name="fillColor" format="color" />
        <attr name="textColor" format="color" />
        <attr name="highlightTextColor" format="color" />
        <attr name="secondaryMarkerColor" format="color" />

        <attr name="maxTextSize" format="dimension" />
        <attr name="minTextSize" format="dimension" />

    </declare-styleable>

    <declare-styleable name="EcgWaveFormView">
        <attr name="ecgCornerRadius" format="dimension" />
        <attr name="strokeColor" format="color" />
        <attr name="strokeWidth" format="dimension" />
        <attr name="gridColor" format="color" />
        <attr name="gridStrokeWidth" format="dimension" />
        <attr name="gridGap" format="dimension" />
        <attr name="backgroundColor" format="color" />
        <attr name="waveLineColor" format="color" />
        <attr name="waveStrokeWidth" format="dimension" />
        <attr name="waveScale" format="float" />
        <attr name="baselineOffset" format="dimension" />
        <attr name="showGrid" format="boolean" />
        <attr name="showBorder" format="boolean" />
        <attr name="autoScale" format="boolean" />
        <attr name="maxVisibleSamples" format="integer" />
    </declare-styleable>

    <declare-styleable name="OTPView">
        <attr name="android:inputType" />
        <attr name="android:importantForAutofill" />
        <attr name="android:autofillHints" />
        <attr name="otp_itemCount" format="integer" />
        <attr name="otp_showCursor" format="boolean" />
        <attr name="otp_underscoreCursor" format="boolean" />
        <attr name="otp_customCursor" format="reference" />
        <attr name="otp_itemWidth" format="dimension" />
        <attr name="otp_itemHeight" format="dimension" />
        <attr name="otp_cursorColor" format="color" />
        <attr name="otp_allcaps" format="boolean" />
        <attr name="otp_marginBetween" format="dimension" />
        <attr name="otp_ispassword" format="boolean" />

        <attr name="otp_textSize" format="dimension" />
        <attr name="otp_textColor" format="integer" />
        <attr name="otp_backgroundImage" format="reference" />
        <attr name="otp_Font" format="reference" />

        <attr name="otp_highlightedTextSize" format="dimension" />
        <attr name="otp_highlightedTextColor" format="integer" />
        <attr name="otp_highlightedBackgroundImage" format="reference" />
        <attr name="otp_highlightedFont" format="reference" />

        <attr name="otp_filledTextSize" format="dimension" />
        <attr name="otp_filledTextColor" format="integer" />
        <attr name="otp_filledBackgroundImage" format="reference" />
        <attr name="otp_filledFont" format="reference" />

    </declare-styleable>

    <declare-styleable name="ScanAnimationView">
        <attr name="scanColor" format="color" />
        <attr name="scanValue" format="string" />
        <attr name="scanValueSuffix" format="string" />
        <attr name="scanUnit" format="string" />
        <attr name="scanValueColor" format="color" />
        <attr name="scanUnitColor" format="color" />

        <attr name="scanProgress" format="float" />
        <attr name="scanProgressMargin" format="dimension" />

        <attr name="scanProgressBackgroundColor" format="color" />
    </declare-styleable>

    <!-- Shared by HdevRingView / HdevBandView / HdevScaleView / HdevCuffView -->
    <declare-styleable name="HdevAnimationView">
        <attr name="hdevColor" format="color" />
        <attr name="hdevProgress" format="float" />
    </declare-styleable>

    <!--BpMeasurementView-->
    <declare-styleable name="BpMeasurementView">
        <attr name="minValueBP" format="float" />
        <attr name="maxValueBP" format="float" />
        <attr name="stepBP" format="float" />
        <attr name="trackColorBP" format="color" />
        <!--  fillColor is split into two stops so it can reproduce the HTML's
                     linear-gradient(180deg, #9be84f, #5fbf6e) — a single color can't
                     express a gradient.  -->
        <attr name="fillColorStart" format="color" />
        <attr name="fillColorEnd" format="color" />
        <attr name="textColorBP" format="color" />
        <attr name="valueTextSize" format="dimension" />
        <attr name="stepTextSize" format="dimension" />
        <attr name="minMaxLabelTopMarginBP" format="dimension" />
        <attr name="minMaxLabelBottomMarginBP" format="dimension" />
        <attr name="barLabelGapBP" format="dimension" />
        <attr name="showValueLabel" format="boolean" />
        <attr name="showStepLabels" format="boolean" />
    </declare-styleable>
</resources>
